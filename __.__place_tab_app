# ------------------------ Callbacks ------------------------

def _set_status(msg: str):
    status.object = msg

def _ensure_pe():
    if pe is None:
        raise RuntimeError(
            "placement_engine_py import failed. Build/install the pybind module in this environment.\n"
            f"Original error: {_IMPORT_ERR}"
        )

def _load_jsons():
    # FileSelector.value is a list of selected files (strings)
    if not file_par.value or not file_blk.value:
        _set_status("❌ Please select both jsonPar.json and jsonBlock.json.")
        return

    par_path = Path(file_par.value[0])
    blk_path = Path(file_blk.value[0])

    try:
        par_obj = load_json_lenient(par_path)
        blk_obj = load_json_lenient(blk_path)
        if not isinstance(par_obj, dict) or not isinstance(blk_obj, dict):
            raise ValueError("Expected both JSON files to be JSON objects (dicts).")
    except Exception as e:
        _set_status(f"❌ Failed to load JSONs: {e}")
        return

    STATE.par_path = par_path
    STATE.block_path = blk_path
    STATE.par_json = par_obj
    STATE.block_json = blk_obj

    # Build param form
    STATE.par_form = JsonForm(root_key="jsonPar", data=par_obj)
    form_container.clear()
    form_container.append(STATE.par_form.build())

    # Build varList controls aligned to block keys
    current_var = par_obj.get("varList", [])
    STATE.varlist_row = make_varlist_controls(blk_obj, current_var)
    varlist_container.clear()
    varlist_container.append(pn.pane.Markdown("### varList (aligned to jsonBlock keys)", margin=(0,0,10,0)))
    varlist_container.append(STATE.varlist_row)

    # show info
    k = list(blk_obj.keys())
    combo_count = 1
    for kk in k:
        if isinstance(blk_obj[kk], list):
            combo_count *= max(1, len(blk_obj[kk]))
    _set_status(
        f"✅ Loaded.\n\n"
        f"- jsonPar: `{par_path}`\n"
        f"- jsonBlock: `{blk_path}`\n"
        f"- block keys: {len(k)}\n"
        f"- sweep combinations (product of list lengths): **{combo_count}**"
    )

def _write_updated_params_copy() -> Optional[Path]:
    if STATE.par_form is None or STATE.par_path is None or STATE.block_json is None:
        _set_status("❌ Load JSONs first.")
        return None

    par_new = STATE.par_form.collect()

    # overwrite varList from dedicated controls (so it matches jsonBlock)
    if STATE.varlist_row is not None:
        par_new["varList"] = read_varlist_from_controls(STATE.varlist_row)

    ts = time.strftime("%Y%m%d_%H%M%S")
    out = STATE.par_path.with_name(f"{STATE.par_path.stem}_updated_{ts}{STATE.par_path.suffix}")
    try:
        save_json_strict(par_new, out)
    except Exception as e:
        _set_status(f"❌ Failed to write updated params file: {e}")
        return None

    _set_status(f"✅ Wrote updated params copy:\n\n`{out}`")
    return out

def _run_single():
    _ensure_pe()

    if STATE.block_path is None or STATE.par_path is None or STATE.block_json is None:
        _set_status("❌ Load JSONs first.")
        return

    par_updated_path = _write_updated_params_copy()
    if par_updated_path is None:
        return

    try:
        runner = pe.Runner()
        runner.jPars_file = str(par_updated_path)
        runner.jBlock_file = str(STATE.block_path)
        runner.execute()

        coords = runner.coords_history()     # (iters,n,2) view
        w = runner.widths()                  # (n,) view
        h = runner.heights()                 # (n,) view
        metrics = runner.metrics_history()   # (iters,) structured view
        iters = int(runner.iterations())
        best_idx = int(runner.best_index())

        STATE.run_data = RunData(
            runner=runner, coords=coords, w=w, h=h, metrics=metrics, iters=iters, best_idx=best_idx
        )

        # update slider + plots
        iter_slider.start = 0
        iter_slider.end = max(0, iters - 1)
        iter_slider.value = 0

        if iters > 0:
            set_rect_data(src_rect, coords[0], w, h)

        # update metric plots (static)
        i = np.arange(iters, dtype=np.int32)
        src_overlap.data = dict(i=i, y=np.asarray(metrics["overlap"]))
        src_area.data = dict(i=i, y=np.asarray(metrics["bbox_area"]))
        src_hpwl.data = dict(i=i, y=np.asarray(metrics["hpwl"]))
        src_aspect.data = dict(i=i, y=np.asarray(metrics["bbox_aspect"]))
        src_boundary.data = dict(i=i, y=np.asarray(metrics["boundary_violation"]))

        best_obj = float(metrics["augmented_objective"][best_idx]) if iters > 0 else float("nan")
        _set_status(
            f"✅ Run complete.\n\n"
            f"- iterations: **{iters}**\n"
            f"- best_idx: **{best_idx}**\n"
            f"- best objective: **{best_obj:.6g}**"
        )
    except Exception as e:
        _set_status(f"❌ Run failed: {e}")

def _on_slider_change(event):
    rd = STATE.run_data
    if rd is None:
        return
    i = int(event.new)
    if i < 0 or i >= rd.iters:
        return
    set_rect_data(src_rect, rd.coords[i], rd.w, rd.h)

def _go_best(_=None):
    rd = STATE.run_data
    if rd is None:
        return
    iter_slider.value = int(rd.best_idx)

async def _run_sweep_async():
    """
    Run all varList combinations in parallel to find best objective.
    Then re-run that best combination once in the main process (single-run) to display.
    """
    _ensure_pe()

    if STATE.block_path is None or STATE.par_form is None or STATE.block_json is None or STATE.par_path is None:
        _set_status("❌ Load JSONs first.")
        return

    # Build the base updated params (in-memory dict)
    base_par = STATE.par_form.collect()
    if STATE.varlist_row is not None:
        base_par["varList"] = read_varlist_from_controls(STATE.varlist_row)

    block_obj = STATE.block_json
    keys = list(block_obj.keys())

    # ranges per key
    ranges = []
    for k in keys:
        v = block_obj[k]
        if not isinstance(v, list) or len(v) == 0:
            ranges.append([0])
        else:
            ranges.append(list(range(len(v))))

    combos = list(itertools.product(*ranges))
    total = len(combos)
    sweep_progress.max = max(1, total)
    sweep_progress.value = 0
    sweep_info.object = f"Running sweep with **{total}** combinations using **{int(sweep_workers.value)}** workers..."

    # We offload the sweep orchestration itself to a thread, but actual work is in subprocesses.
    import asyncio
    import concurrent.futures
    import multiprocessing as mp

    ctx = mp.get_context("spawn")
    max_workers = int(sweep_workers.value)

    # Use a temp directory for params files written by workers.
    tmpdir = Path(tempfile.mkdtemp(prefix="placement_sweep_"))

    def run_sweep_blocking():
        best_obj = math.inf
        best_combo = None

        with concurrent.futures.ProcessPoolExecutor(max_workers=max_workers, mp_context=ctx) as ex:
            futs = []
            for combo in combos:
                varlist = list(combo)
                futs.append(ex.submit(
                    sweep_one_varlist,
                    base_par,
                    str(STATE.block_path),
                    varlist,
                    str(tmpdir),
                ))

            done = 0
            for fut in concurrent.futures.as_completed(futs):
                done += 1
                try:
                    obj, combo_ret = fut.result()
                except Exception:
                    # ignore worker failures but keep going
                    obj, combo_ret = math.inf, None
                if obj < best_obj:
                    best_obj = obj
                    best_combo = combo_ret
                # progress update is handled outside (async) by returning counts
                yield done, best_obj, best_combo

    # Consume the generator without blocking UI too long
    best_obj = math.inf
    best_combo = None
    loop = asyncio.get_running_loop()

    # run the blocking generator in a thread and stream progress back
    def _drain():
        out = []
        for step in run_sweep_blocking():
            out.append(step)
        return out

    steps = await loop.run_in_executor(None, _drain)

    for done, bo, bc in steps:
        sweep_progress.value = done
        best_obj, best_combo = bo, bc

    if best_combo is None:
        sweep_info.object = "❌ Sweep completed but no successful run was found."
        return

    sweep_info.object = (
        f"✅ Sweep done.\n\n"
        f"- best objective: **{best_obj:.6g}**\n"
        f"- best varList: **{list(best_combo)}**\n\n"
        f"Re-running best varList once to load full history..."
    )

    # apply best varList to controls
    if STATE.varlist_row is not None:
        # update IntInputs in place
        i = 0
        for col in STATE.varlist_row:
            if isinstance(col, pn.Column):
                for w in col:
                    if isinstance(w, pn.widgets.IntInput):
                        w.value = int(best_combo[i])
                        i += 1

    # now just run single-run path (writes updated file + executes + plots)
    _run_single()

def _run_sweep(_=None):
    # Schedule async sweep
    import asyncio
    try:
        asyncio.get_running_loop()
        pn.state.execute(_run_sweep_async)
    except RuntimeError:
        # no running loop (rare). Panel will have one; fallback anyway.
        pn.state.execute(_run_sweep_async)

# wire callbacks
btn_load.on_click(lambda _: _load_jsons())
btn_update.on_click(lambda _: _write_updated_params_copy())
btn_run.on_click(lambda _: _run_single())
btn_best.on_click(_go_best)
iter_slider.param.watch(_on_slider_change, "value")
btn_sweep.on_click(_run_sweep)

