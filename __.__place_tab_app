namespace {
using json = nlohmann::json;

static std::vector<int> parse_varlist_from_pars(const json& jPars) {
  std::vector<int> out;
  auto it = jPars.find("varList");
  if (it == jPars.end() || !it->is_array()) return out;

  out.reserve(it->size());
  for (const auto& v : *it) {
    if (!v.is_number_integer()) out.push_back(0);
    else out.push_back(v.get<int>());
  }
  return out;
}

// IMPORTANT: nlohmann::json uses std::map by default -> keys iterate in SORTED order.
// To be deterministic and match typical existing C++ behavior, we also sort keys here.
static json select_blocks_by_varlist_sorted_keys(const json& jBlock,
                                                const std::vector<int>& varList) {
  if (!jBlock.is_object()) {
    throw std::runtime_error("jsonBlock must be a JSON object at top level.");
  }

  std::vector<std::string> keys;
  keys.reserve(jBlock.size());
  for (auto it = jBlock.begin(); it != jBlock.end(); ++it) keys.push_back(it.key());
  std::sort(keys.begin(), keys.end());

  json out = json::object();
  out.reserve(keys.size());

  for (std::size_t i = 0; i < keys.size(); ++i) {
    const auto& k = keys[i];
    const auto& v = jBlock.at(k);

    if (v.is_array() && !v.empty()) {
      std::size_t idx = 0;
      if (i < varList.size() && varList[i] >= 0) idx = static_cast<std::size_t>(varList[i]);
      if (idx >= v.size()) idx = v.size() - 1;
      out[k] = v[idx];               // pick dict at idx
    } else {
      out[k] = v;                    // passthrough (non-array or empty array)
    }
  }
  return out;
}
} // namespace

