# ------------------------ JSON loading (lenient) ------------------------

_TRAILING_COMMA_RE = re.compile(r",(\s*[\]}])", flags=re.MULTILINE)
_ELLIPSIS_LINE_RE = re.compile(r"^\s*\.\.\.\s*$", flags=re.MULTILINE)

def load_json_lenient(path: str | Path) -> Any:
    """
    Load JSON that may contain:
      - trailing commas before ']' or '}'
      - standalone lines containing '...'
    Your real files should be strict JSON; this is just to tolerate common editing artifacts.
    """
    p = Path(path)
    s = p.read_text(encoding="utf-8", errors="replace")
    s = _ELLIPSIS_LINE_RE.sub("", s)

    # iteratively remove trailing commas
    prev = None
    while prev != s:
        prev = s
        s = _TRAILING_COMMA_RE.sub(r"\1", s)

    return json.loads(s)

def save_json_strict(obj: Any, out_path: str | Path) -> Path:
    out_path = Path(out_path)
    out_path.parent.mkdir(parents=True, exist_ok=True)
    with out_path.open("w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2)
    return out_path

# ------------------------ Widget builder ------------------------

_ENUM_OPTIONS = {
    # optimizer
    "algorithm": ["DE", "CMAES", "SA", "SGD", "Adam"],
    "stopping_criteria": ["max_iter", "target_objective"],
    "strategy": ["best1bin", "rand1bin", "best2bin", "rand2bin"],
    # constraints
    "normalization": ["no norm", "canvas_area", "total_rect_area", "scale_len"],
    "aggregation": ["sum", "mean", "max"],
    "type": ["overlap", "boundary", "aspect"],
}

def _widget_for_value(key: str, value: Any) -> pn.viewable.Viewable:
    # enums
    if isinstance(value, str) and key in _ENUM_OPTIONS:
        return pn.widgets.Select(name=key, options=_ENUM_OPTIONS[key], value=value)

    # scalar types
    if isinstance(value, bool):
        return pn.widgets.Checkbox(name=key, value=value)
    if isinstance(value, int) and not isinstance(value, bool):
        return pn.widgets.IntInput(name=key, value=value)
    if isinstance(value, float):
        return pn.widgets.FloatInput(name=key, value=value, step=0.01)
    if isinstance(value, str):
        return pn.widgets.TextInput(name=key, value=value)

    # list
    if isinstance(value, list):
        # Special handling for varList: list of indices
        if key == "varList" and all(isinstance(x, int) for x in value):
            items = []
            for i, v in enumerate(value):
                items.append(pn.widgets.IntInput(name=f"varList[{i}]", value=int(v), width=120))
            return pn.Row(*items, sizing_mode="stretch_width")

        # simple list
        return pn.widgets.TextAreaInput(name=key, value=json.dumps(value), height=90)

    # dict fallback
    return pn.widgets.TextAreaInput(name=key, value=json.dumps(value, indent=2), height=140)

@dataclass
class JsonForm:
    root_key: str
    data: Dict[str, Any]
    widgets: Dict[Tuple[str, ...], pn.viewable.Viewable] = field(default_factory=dict)

    def build(self) -> pn.Column:
        col = pn.Column(sizing_mode="stretch_width")
        col.append(pn.pane.Markdown(f"### {self.root_key}", margin=(0, 0, 10, 0)))
        col.append(self._build_node((self.root_key,), self.data))
        return col

    def _build_node(self, path: Tuple[str, ...], node: Any) -> pn.viewable.Viewable:
        if isinstance(node, dict):
            # group in an accordion for readability
            acc_items = []
            for k, v in node.items():
                child_path = path + (k,)
                acc_items.append((k, self._build_node(child_path, v)))
            acc = pn.Accordion(*acc_items, active=list(range(len(acc_items))), sizing_mode="stretch_width")
            return acc

        # leaf widget
        w = _widget_for_value(path[-1], node)
        self.widgets[path] = w
        return w

    def collect(self) -> Dict[str, Any]:
        """Return a deep-updated copy of self.data using widget values."""
        def set_in(obj: Any, p: Tuple[str, ...], val: Any):
            # p includes root_key at index 0
            cur = obj
            for k in p[1:-1]:
                cur = cur[k]
            cur[p[-1]] = val

        out = json.loads(json.dumps(self.data))  # deep copy
        for path, w in self.widgets.items():
            key = path[-1]
            if isinstance(w, pn.widgets.TextAreaInput):
                # for TextAreaInput, try to parse JSON; fallback to raw string
                try:
                    v = json.loads(w.value)
                except Exception:
                    v = w.value
            elif isinstance(w, pn.widgets.Select):
                v = w.value
            elif isinstance(w, pn.widgets.Checkbox):
                v = bool(w.value)
            elif isinstance(w, pn.widgets.IntInput):
                v = int(w.value)
            elif isinstance(w, pn.widgets.FloatInput):
                v = float(w.value)
            elif isinstance(w, pn.widgets.TextInput):
                v = w.value
            elif isinstance(w, pn.Row) and key == "varList":
                # handled separately below
                continue
            else:
                v = getattr(w, "value", None)

            # varList row: reconstruct from its IntInputs
            if key == "varList" and isinstance(w, pn.Row):
                vals = []
                for item in w:
                    if isinstance(item, pn.widgets.IntInput):
                        vals.append(int(item.value))
                v = vals

            set_in(out, path, v)

        # Special: if varList is rendered as Row at root
        # (in our build, varList leaf widget is a Row)
        var_path = (self.root_key, "varList")
        if var_path in self.widgets and isinstance(self.widgets[var_path], pn.Row):
            vals = []
            for item in self.widgets[var_path]:
                if isinstance(item, pn.widgets.IntInput):
                    vals.append(int(item.value))
            out["varList"] = vals

        return out

def make_varlist_controls(block_json: Dict[str, Any], current: List[int]) -> pn.Row:
    """Rebuild varList controls sized to number of keys in block_json."""
    keys = list(block_json.keys())
    n = len(keys)
    cur = list(current) if isinstance(current, list) else []
    if len(cur) < n:
        cur = cur + [0] * (n - len(cur))
    if len(cur) > n:
        cur = cur[:n]

    row_items = []
    for i, k in enumerate(keys):
        max_idx = max(0, len(block_json[k]) - 1) if isinstance(block_json[k], list) else 0
        row_items.append(
            pn.Column(
                pn.pane.Markdown(f"**{k}**", margin=(0,0,0,0)),
                pn.widgets.IntInput(name=f"varList[{i}]", value=int(cur[i]), start=0, end=max_idx, width=120),
                margin=(0,10,0,0)
            )
        )
    return pn.Row(*row_items, sizing_mode="stretch_width")

def read_varlist_from_controls(var_row: pn.Row) -> List[int]:
    out = []
    for col in var_row:
        if isinstance(col, pn.Column):
            for w in col:
                if isinstance(w, pn.widgets.IntInput):
                    out.append(int(w.value))
    return out

# ------------------------ Bokeh plotting ------------------------

def make_rect_plot() -> Tuple[figure, ColumnDataSource]:
    src = ColumnDataSource(data=dict(x=[], y=[], w=[], h=[]))
    p = figure(
        title="Block placement",
        width=800, height=800,
        match_aspect=True,
        tools="pan,wheel_zoom,reset,save",
        active_scroll="wheel_zoom",
    )
    p.rect(x="x", y="y", width="w", height="h", source=src, fill_alpha=0.35, line_alpha=0.9)
    p.xaxis.axis_label = "X"
    p.yaxis.axis_label = "Y"
    return p, src

def make_metric_plot(title: str, y_key: str) -> Tuple[figure, ColumnDataSource]:
    src = ColumnDataSource(data=dict(i=[], y=[]))
    p = figure(title=title, width=380, height=240, tools="pan,wheel_zoom,reset,save", active_scroll="wheel_zoom")
    p.line(x="i", y="y", source=src)
    p.xaxis.axis_label = "Iteration"
    p.yaxis.axis_label = y_key
    return p, src

def set_rect_data(src: ColumnDataSource, coords_i: np.ndarray, w: np.ndarray, h: np.ndarray):
    # coords_i: (n,2)
    src.data = dict(
        x=np.asarray(coords_i[:, 0]),
        y=np.asarray(coords_i[:, 1]),
        w=np.asarray(w),
        h=np.asarray(h),
    )

