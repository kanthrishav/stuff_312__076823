    return out_path

def sweep_one_varlist(base_par: Dict[str, Any], block_path: str, varlist: List[int], tmpdir: str) -> Tuple[float, Tuple[int, ...]]:
    """
    Run one optimization for a given varList.
    Returns: (best_objective, varlist_tuple)

    IMPORTANT:
    - returns only scalar objective + varList to keep IPC overhead tiny.
    - the main UI will re-run the best varList once to load full history (zero-copy).
    """
    import placement_engine_py as pe

    par_path = _save_params(base_par, varlist, tmpdir)

    runner = pe.Runner()
    runner.jPars_file = str(par_path)
    runner.jBlock_file = str(block_path)
    runner.execute()

    bm = runner.best_metrics()
    obj = float(bm.get("augmented_objective", math.inf))
