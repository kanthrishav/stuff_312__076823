def _save_params(base_par: Dict[str, Any], varlist: List[int], out_dir: str) -> Path:
    out = dict(base_par)
    out["varList"] = list(varlist)
    out_path = Path(out_dir) / f"jsonPar_var_{'_'.join(map(str,varlist))}.json"
    out_path.parent.mkdir(parents=True, exist_ok=True)
    with out_path.open("w", encoding="utf-8") as f:
