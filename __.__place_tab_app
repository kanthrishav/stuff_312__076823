# runner_worker.py
from __future__ import annotations

import json
import math
from typing import Any, Dict, List, Tuple, Optional

_BLOCK_JSON_STR: Optional[str] = None

def init_worker(block_json_str: str):
    """Initializer for each worker process: store jsonBlock string once."""
    global _BLOCK_JSON_STR
    _BLOCK_JSON_STR = block_json_str

def sweep_one_varlist(par_base: Dict[str, Any], varlist: List[int]) -> Tuple[float, Tuple[int, ...]]:
    """
    Run one optimization for a given varList (NO file IO).
    Returns (best_objective, varlist_tuple)
    """
    global _BLOCK_JSON_STR
    if _BLOCK_JSON_STR is None:
        raise RuntimeError("Worker not initialized. init_worker(block_json_str) was not called.")

    import placement_engine_py as pe

    par = dict(par_base)
    par["varList"] = list(varlist)

    # Compact JSON => less IPC + faster C++ parse
    par_str = json.dumps(par, separators=(",", ":"))

    runner = pe.Runner()
    runner.execute_from_json_strings(par_str, _BLOCK_JSON_STR)

    bm = runner.best_metrics()
    obj = float(bm.get("augmented_objective", math.inf))
    return obj, tuple(varlist)

