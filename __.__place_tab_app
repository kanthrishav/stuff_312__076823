        varlist = list(combo)
        fut = ex.submit(sweep_one_varlist, base_par_dict, varlist)
        inflight.add(fut)
        return True

    for _ in range(window):
        if not submit_next():
            break

    done = 0
    while inflight:
        done_futs, inflight = concurrent.futures.wait(
            inflight, return_when=concurrent.futures.FIRST_COMPLETED
        )
        for fut in done_futs:
            done += 1
            try:
