set(CMAKE_CXX_STANDARD_REQUIRED ON)

# ---- Dependency: nlohmann_json (no git required) ----
find_package(nlohmann_json CONFIG QUIET)
if(NOT nlohmann_json_FOUND)
    include(FetchContent)
    # Downloads a release tarball (no git.exe needed). Requires internet.
    FetchContent_Declare(
        nlohmann_json
        URL https://github.com/nlohmann/json/releases/download/v3.11.3/json.tar.xz
    )
    FetchContent_MakeAvailable(nlohmann_json)
endif()

# ---- Core library ----
add_library(blocks_lib STATIC
    src/blocks.cpp
)
target_include_directories(blocks_lib PUBLIC
    ${CMAKE_CURRENT_SOURCE_DIR}/include
)
target_link_libraries(blocks_lib PUBLIC nlohmann_json::nlohmann_json)

# ---- Executable ----
add_executable(blocks_app
    src/main.cpp
)
target_link_libraries(blocks_app PRIVATE blocks_lib)

# ---- Optional pybind build ----
option(BUILD_PYBIND "Build pybind11 Python module" ON)

if(BUILD_PYBIND)
    find_package(Python3 3.11 REQUIRED COMPONENTS Interpreter Development.Module)

    # Use pybind11 from the active venv Python (no git download)
    execute_process(
        COMMAND "${Python3_EXECUTABLE}" -m pybind11 --cmakedir
        OUTPUT_VARIABLE pybind11_cmake_dir
        OUTPUT_STRIP_TRAILING_WHITESPACE
    )

    if(NOT EXISTS "${pybind11_cmake_dir}")
        message(FATAL_ERROR "pybind11 CMake dir not found. Got: '${pybind11_cmake_dir}'. Is pybind11 installed in this venv?")
    endif()

    list(APPEND CMAKE_PREFIX_PATH "${pybind11_cmake_dir}")
    find_package(pybind11 CONFIG REQUIRED)

    pybind11_add_module(blocks_py
        src/pybind_module.cpp
    )
    target_link_libraries(blocks_py PRIVATE blocks_lib)
endif()






