// nlohmann/json
#include <nlohmann/json.hpp>
using nlohmann::json;

Block::Block(int id, std::string name, double width, double height)
    : id_(id),
      name_(std::move(name)),
      width_(width),
      height_(height),
      x_(0.0),
      y_(0.0) {}

void Block::print_info() const {
    std::cout
        << "[Block::print_info] name=\"" << name_ << "\""
        << ", id=" << id_
        << ", width=" << width_
        << ", height=" << height_
        << ", x=" << x_
        << ", y=" << y_
        << "\n";
}

void Block::do_work(int work_units) const {
    std::cout
        << "[Block::do_work] \"" << name_ << "\" (id=" << id_ << ") doing "
        << work_units << " unit(s) of work"
        << " with (w,h)=(" << width_ << "," << height_ << ")"
        << "\n";
}

static std::filesystem::path choose_json_path_or_throw(const std::string& requested) {
    namespace fs = std::filesystem;

    std::vector<fs::path> candidates;

    if (!requested.empty()) {
        candidates.emplace_back(fs::path(requested));
    } else {
        // Common cases:
        // - run from repo root: configs/input.json
        // - run from build dir: ../configs/input.json or ../../configs/input.json, etc.
        candidates.emplace_back("configs/input.json");
        candidates.emplace_back("../configs/input.json");
        candidates.emplace_back("../../configs/input.json");
        candidates.emplace_back("../../../configs/input.json");
    }

    for (const auto& p : candidates) {
        std::error_code ec;
        if (fs::exists(p, ec) && fs::is_regular_file(p, ec)) {
            return p;
        }
    }

    std::ostringstream oss;
    oss << "Could not find input.json. Tried paths:\n";
    for (const auto& p : candidates) oss << "  - " << p.string() << "\n";
    throw std::runtime_error(oss.str());
}

std::vector<Block> load_blocks_from_json(const std::string& json_path) {
    namespace fs = std::filesystem;

    const fs::path path = choose_json_path_or_throw(json_path);

    std::ifstream ifs(path);
    if (!ifs) {
        throw std::runtime_error("Failed to open JSON file: " + path.string());
    }

    json j;
    try {
        ifs >> j;
    } catch (const std::exception& e) {
        throw std::runtime_error(std::string("JSON parse error in ") + path.string() + ": " + e.what());
    }

    if (!j.is_object()) {
        throw std::runtime_error("Top-level JSON must be an object (dict). File: " + path.string());
    }

    std::vector<Block> blocks;
    blocks.reserve(j.size());

    for (auto it = j.begin(); it != j.end(); ++it) {
        const std::string block_name = it.key();
        const json& arr = it.value();

        if (!arr.is_array() || arr.empty()) {
            throw std::runtime_error("Block \"" + block_name + "\" must be a non-empty list.");
        }
        const json& first = arr.at(0);
        if (!first.is_object()) {
            throw std::runtime_error("Block \"" + block_name + "\": first element must be a dict/object.");
        }

        // Required keys in the first dict
        if (!first.contains("ID") || !first.contains("width") || !first.contains("height")) {
            throw std::runtime_error(
                "Block \"" + block_name + "\": first dict must contain keys: ID, width, height."
            );
        }

        const int id = first.at("ID").get<int>();
        const double width = first.at("width").get<double>();
        const double height = first.at("height").get<double>();

        blocks.emplace_back(id, block_name, width, height);
        // x,y remain 0.0 per requirement
    }

    return blocks;
}




#include "blocks.h"
#include <iostream>
#include <vector>

int main(int argc, char** argv) {
    try {
        // Optional: allow explicit path override via argv[1]
        const std::string path = (argc >= 2) ? std::string(argv[1]) : std::string("");

        std::vector<Block> blocks = load_blocks_from_json(path);

        std::cout << "Loaded " << blocks.size() << " block(s)\n";

        for (auto& b : blocks) {
            b.print_info();
            b.do_work(2);
        }

        return 0;
    } catch (const std::exception& e) {
        std::cerr << "ERROR: " << e.what() << "\n";
        return 1;
    }
}





#include <pybind11/pybind11.h>
#include <pybind11/stl.h>

#include "blocks.h"

namespace py = pybind11;

PYBIND11_MODULE(blocks_py, m) {
    m.doc() = "pybind11 example exposing Block class and JSON loader";

    py::class_<Block>(m, "Block")
        .def(py::init<int, std::string, double, double>(),
             py::arg("id"), py::arg("name"), py::arg("width"), py::arg("height"))
        .def("print_info", &Block::print_info)
        .def("do_work", &Block::do_work, py::arg("work_units"))

        .def_property_readonly("id", &Block::id)
        .def_property_readonly("name", &Block::name)
        .def_property_readonly("width", &Block::width)
        .def_property_readonly("height", &Block::height)

        .def_property_readonly("x", &Block::x)
        .def_property_readonly("y", &Block::y)
        .def("set_position", &Block::set_position, py::arg("x"), py::arg("y"))

        .def("__repr__", [](const Block& b) {
            return "<Block name='" + b.name() + "' id=" + std::to_string(b.id()) +
                   " w=" + std::to_string(b.width()) +
                   " h=" + std::to_string(b.height()) +
                   " x=" + std::to_string(b.x()) +
                   " y=" + std::to_string(b.y()) + ">";
        });

    // The requested "create list of Block objects initialized with JSON directly"
    m.def("load_blocks_from_json", &load_blocks_from_json,
          py::arg("json_path") = "",
          "Load blocks from JSON file and return a list of Block objects.");
}





