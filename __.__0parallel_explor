    # ------------------------- Public -------------------------

    def panel(self):
        # Start periodic updates once panel is constructed (fast checks; no heavy history retention).
        if self._cb is None:
            self._cb = pn.state.add_periodic_callback(self._tick, period=250, start=True)
        return self._panel

    # ------------------------- Internals -------------------------

    def _safe_call(self, name, fn):
        if self._runner is None:
            self._status.object = f"### Parallel Exploration\nRunner not created. ({name} ignored)"
            return
        try:
            fn()
        except Exception as e:
            self._status.object = f"### Parallel Exploration\n**Error on {name}:** `{e}`"

    def _on_load(self, *_):
        if not self._par_file.value or not self._blk_file.value:
            self._status.object = "### Parallel Exploration\nPlease provide both jPar and jBlock."
            return

        try:
            par_txt = self._par_file.value.decode("utf-8")
            blk_txt = self._blk_file.value.decode("utf-8")
            self._par_json = json.loads(par_txt)
            self._blk_json = json.loads(blk_txt)
        except Exception as e:
            self._status.object = f"### Parallel Exploration\n**JSON parse error:** `{e}`"
            return

        # Build block order matching C++ typical map order expectation: sorted keys.
        self._block_order = sorted(list(self._blk_json.keys()))
        var_list = self._par_json.get("varList", [])
        if len(var_list) != len(self._block_order):
            # Still allow (some files may use stable insertion); fallback to insertion order
            self._block_order = list(self._blk_json.keys())

        self._dims_wh = self._extract_dims(self._blk_json, self._block_order, self._par_json.get("varList", []))
        self._pins = self._extract_pins(self._blk_json, self._block_order, self._par_json.get("varList", []))

        self._status.object = (
            "### Parallel Exploration\n"
            f"Loaded **jPar** + **jBlock**.\n\n"
            f"- Blocks: **{len(self._block_order)}**\n"
            f"- Pins: **{len(self._pins)}**\n"
        )

    def _on_create(self, *_):
        if self._par_json is None or self._blk_json is None:
            self._status.object = "### Parallel Exploration\nLoad jPar + jBlock first."
            return

        try:
            self._par_path = self._write_tmp_json("parallel_exploration_jpar_", self._par_json)
            self._blk_path = self._write_tmp_json("parallel_exploration_jblock_", self._blk_json)
            self._runner = pe.ParallelExplorationRunner(self._par_path, self._blk_path)

            k = self._runner.history_keep_top_k()
            self._status.object = (
                "### Parallel Exploration\n"
                f"Runner created.\n\n"
                f"- planned_runs: **{self._runner.planned_runs()}**\n"
                f"- max_parallel: **{self._runner.max_parallel()}**\n"
                f"- history_keep_top_k: **{k}**\n"
            )
        except Exception as e:
            self._status.object = f"### Parallel Exploration\n**Create runner failed:** `{e}`"
            self._runner = None

    def _on_pick_global_best(self, *_):
        if self._runner is None:
            self._status.object = "### Parallel Exploration\nRunner not created."
            return

        # Build SelectionProgram for per-run best-index selection
        prog = pe.SelectionProgram()
        prog.add_objective(self._sel_metric.value, self._sel_op.value, float(self._sel_tie_eps.value))

        if self._filter_no_overlap.value:
            prog.add_filter(pe.Filter(pe.Metric.overlap, pe.FOp.le, float(self._filter_overlap_eps.value), 0.0, 0))
        if self._filter_no_boundary.value:
            prog.add_filter(pe.Filter(pe.Metric.boundary_violation, pe.FOp.le, float(self._filter_boundary_eps.value), 0.0, 0))

        try:
            top10 = list(self._runner.top_history_run_ids())
        except Exception as e:
            self._status.object = f"### Parallel Exploration\nCannot query top histories: `{e}`"
            return

        if not top10:
            self._status.object = "### Parallel Exploration\nNo completed top-history runs yet."
            return

        # Global selection: pick best among selected indices using the same primary objective
        best = None  # (run_id, idx, metric_value)
        metric_field = self._metric_field_name(self._sel_metric.value)
        for rid in top10:
            try:
                r = self._runner.runner(int(rid))  # will only exist for history-retained runs
                idx = int(r.select_best_index(prog))
                mh = r.metrics_history()
                val = float(mh[idx][metric_field])
                if best is None:
                    best = (int(rid), idx, val)
                else:
                    if self._sel_op.value == pe.ObjOp.arg_min:
                        if val < best[2]:
                            best = (int(rid), idx, val)
                    else:
                        if val > best[2]:
                            best = (int(rid), idx, val)
            except Exception:
                continue

        if best is None:
            self._status.object = "### Parallel Exploration\nGlobal best: no feasible candidate found under current filters."
            return

        self._override_best = (best[0], best[1])
        self._status.object = (
            "### Parallel Exploration\n"
            f"**GLOBAL best selected** (top-10): run_id={best[0]} iter={best[1]} ({metric_field}={best[2]:.6g})\n\n"
            "Plot #1 updated."
        )
        self._update_plot_from_override()

    def _on_clear_override(self, *_):
        self._override_best = None
        self._status.object = "### Parallel Exploration\nPlot #1 override cleared."
        self._tick()

    def _on_show_final(self, *_):
        if self._runner is None:
            self._status.object = "### Parallel Exploration\nRunner not created."
            return
        rid = int(self._browse_run_id.value)
        try:
            coords = np.array(self._runner.run_final_coords(rid), copy=False)
            m = self._runner.run_final_metrics(rid)
            self._fill_sources_for_plot(self._plot_sources[0], coords, m, label=f"FINAL run={rid}")
            self._apply_square_ranges(self._plots[0], m)
            self._status.object = f"### Parallel Exploration\nPlot #1 now shows FINAL placement for run_id={rid}."
        except Exception as e:
            self._status.object = f"### Parallel Exploration\nCannot show final for run_id={rid}: `{e}`"

    def _tick(self):
        # Lightweight periodic refresh (no history hoarding).
        if self._runner is None:
            self._stats.object = ""
            return

        try:
            planned = int(self._runner.planned_runs())
            completed = int(self._runner.completed_count())
            running = int(self._runner.running_count())
            failed = int(self._runner.failed_count())
            best_id = int(self._runner.best_run_id()) if completed > 0 else -1

            self._stats.object = (
                f"**planned_runs:** {planned}  \n"
                f"**running:** {running}  | **completed:** {completed}  | **failed:** {failed}  \n"
                f"**best_run_id:** {best_id}  | **history retained (top-K):** {len(self._runner.top_history_run_ids())}/{self._runner.history_keep_top_k()}"
            )
        except Exception:
            return

        # Update plots (top-4) — cheap, only 4 runs
        try:
            top4 = list(self._runner.top_best_run_ids(4))
        except Exception:
            top4 = []

        # Plot #1: override if present
        if self._override_best is not None:
            self._update_plot_from_override()
        else:
            self._fill_plot_rank(0, top4, rank=0)

        self._fill_plot_rank(1, top4, rank=1)
        self._fill_plot_rank(2, top4, rank=2)
        self._fill_plot_rank(3, top4, rank=3)

        # Refresh tables at a slower cadence (keeps UI fast for 10k runs)
        now = time.time()
        if now - self._last_table_refresh > 1.0:
            self._last_table_refresh = now
            self._refresh_tables()

    def _refresh_tables(self):
        try:
            top_ids = list(self._runner.top_best_run_ids(self._runner.history_keep_top_k()))
        except Exception:
            top_ids = []

        rows = []
        for i, rid in enumerate(top_ids, start=1):
            try:
                sig = int(self._runner.run_signature_id(int(rid)))
                bi = int(self._runner.run_best_iter(int(rid)))
                bm = self._runner.run_best_metrics(int(rid))
                rows.append({
                    "rank": i,
                    "run_id": int(rid),
                    "sig_id": sig,
                    "best_iter": bi,
                    "bbox_area": bm.get("bbox_area", np.nan),
                    "hpwl": bm.get("hpwl", np.nan),
                    "overlap": bm.get("overlap", np.nan),
                    "boundary": bm.get("boundary_violation", np.nan),
                    "aspect_viol": bm.get("aspect_ratio_violation", np.nan),
                    "dead_space": bm.get("dead_space_area", np.nan),
                    "symmetry": bm.get("symmetry_violation", np.nan),
                    "aug_obj": bm.get("augmented_objective", np.nan),
                    "has_history": bool(self._runner.run_has_history(int(rid))),
                })
            except Exception:
                continue

        self._top_table.value = pd.DataFrame(rows)

        # Signature bests
        try:
            sig_map = self._runner.best_runs_by_signature()
            sig_rows = [{"sig_id": int(k), "best_run_id": int(v[0]), "best_bbox_area": float(v[1])} for k, v in sig_map.items()]
            sig_rows.sort(key=lambda x: x["best_bbox_area"])
            self._sig_table.value = pd.DataFrame(sig_rows)
        except Exception:
            self._sig_table.value = pd.DataFrame(columns=["sig_id", "best_run_id", "best_bbox_area"])

    def _fill_plot_rank(self, plot_idx, top_ids, rank):
        if rank >= len(top_ids):
            self._clear_plot(self._plot_sources[plot_idx], self._plots[plot_idx])
            return

        rid = int(top_ids[rank])
        try:
            # Use best iter from monitor (fast), and use full history runner (top-K runs retain it).
            bi = int(self._runner.run_best_iter(rid))
            r = self._runner.runner(rid)
            coords = np.array(r.coords_at(bi), copy=False)
            mh = r.metrics_history()
            m = mh[bi]
            self._fill_sources_for_plot(self._plot_sources[plot_idx], coords, m, label=f"TOP{rank+1} run={rid} iter={bi}")
            self._apply_square_ranges(self._plots[plot_idx], m)
        except Exception:
            self._clear_plot(self._plot_sources[plot_idx], self._plots[plot_idx])

    def _update_plot_from_override(self):
        if self._override_best is None or self._runner is None:
            return
        rid, it = self._override_best
        try:
            r = self._runner.runner(int(rid))
            coords = np.array(r.coords_at(int(it)), copy=False)
            mh = r.metrics_history()
            m = mh[int(it)]
            self._fill_sources_for_plot(self._plot_sources[0], coords, m, label=f"GLOBAL run={rid} iter={it}")
            self._apply_square_ranges(self._plots[0], m)
        except Exception:
            pass

    # ------------------------- Canvas helpers -------------------------

    def _make_canvas_sources(self):
        return {
            "rect": ColumnDataSource(data=dict(x=[], y=[], w=[], h=[], rect_id=[])),
            "pins": ColumnDataSource(data=dict(x=[], y=[], w=[], h=[], pin_id=[], ex=[], ey=[])),
            "bbox": ColumnDataSource(data=dict(x=[], y=[], w=[], h=[])),
            "poly": ColumnDataSource(data=dict(xs=[], ys=[])),  # for multi_polygons
            "label": ColumnDataSource(data=dict(x=[], y=[], text=[])),
        }

    def _make_canvas_fig(self, srcs, title=""):
        p = figure(
            title=title,
            width=520, height=360,
            match_aspect=True,
            sizing_mode="stretch_both",
