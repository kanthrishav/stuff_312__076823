        p.yaxis.major_label_text_color = self._COLORS["text"]

        rect_r = p.rect("x", "y", "w", "h", source=srcs["rect"], fill_alpha=0.25, line_alpha=0.9, line_width=1.5)
        p.text("x", "y", "rect_id", source=srcs["rect"], text_color=self._COLORS["text"], text_align="center", text_baseline="middle")

        pin_r = p.rect("x", "y", "w", "h", source=srcs["pins"], fill_alpha=0.6, line_alpha=0.9)
        p.text("x", "y", "pin_id", source=srcs["pins"], text_color=self._COLORS["pin"], text_align="center", text_baseline="middle")
        p.segment("x", "y", "ex", "ey", source=srcs["pins"], line_alpha=0.35)

        p.rect("x", "y", "w", "h", source=srcs["bbox"], fill_alpha=0.0, line_alpha=0.95, line_width=2, line_dash="dashed")

        # dead-space / envelope polygon (multi_polygons)
        p.multi_polygons("xs", "ys", source=srcs["poly"], fill_alpha=0.10, line_alpha=0.85)

        p.text("x", "y", "text", source=srcs["label"], text_color=self._COLORS["accent"])

        p.add_tools(HoverTool(renderers=[rect_r], tooltips=[("block", "@rect_id"), ("x", "@x"), ("y", "@y"), ("w", "@w"), ("h", "@h")]))
        p.add_tools(HoverTool(renderers=[pin_r], tooltips=[("pin", "@pin_id"), ("x", "@x"), ("y", "@y")]))

        p.x_range = Range1d(0, 100)
        p.y_range = Range1d(0, 100)
        return p

    def _clear_plot(self, srcs, fig):
        srcs["rect"].data = dict(x=[], y=[], w=[], h=[], rect_id=[])
        srcs["pins"].data = dict(x=[], y=[], w=[], h=[], pin_id=[], ex=[], ey=[])
        srcs["bbox"].data = dict(x=[], y=[], w=[], h=[])
        srcs["poly"].data = dict(xs=[], ys=[])
        srcs["label"].data = dict(x=[], y=[], text=[])
        fig.x_range.start, fig.x_range.end = 0, 100
        fig.y_range.start, fig.y_range.end = 0, 100

    def _fill_sources_for_plot(self, srcs, coords_xy, metrics_row, label=""):
        # dims
        if self._dims_wh is None:
            return

        w = self._dims_wh[:, 0]
        h = self._dims_wh[:, 1]

        x = coords_xy[:, 0]
        y = coords_xy[:, 1]

        rect_ids = self._block_order[:len(x)]
        srcs["rect"].data = dict(x=x.tolist(), y=y.tolist(), w=w[:len(x)].tolist(), h=h[:len(x)].tolist(), rect_id=rect_ids)

        # pins
        px, py, pw, ph, pid, ex, ey = [], [], [], [], [], [], []
        for pin in self._pins:
            bi = pin["block_i"]
            if bi >= len(x):
                continue
            px.append(float(x[bi] + pin["ox"]))
            py.append(float(y[bi] + pin["oy"]))
            pw.append(float(pin["w"]))
            ph.append(float(pin["h"]))
            pid.append(pin["id"])
            ex.append(float(x[bi] + pin["ox"]))
            ey.append(float(y[bi] + pin["oy"]))
        srcs["pins"].data = dict(x=px, y=py, w=pw, h=ph, pin_id=pid, ex=ex, ey=ey)

        # bbox from metrics struct/row
        try:
            cx = float(metrics_row["bbox_cx"])
            cy = float(metrics_row["bbox_cy"])
            bw = float(metrics_row["bbox_w"])
            bh = float(metrics_row["bbox_h"])
            srcs["bbox"].data = dict(x=[cx], y=[cy], w=[bw], h=[bh])
        except Exception:
            srcs["bbox"].data = dict(x=[], y=[], w=[], h=[])

        # polygon (best-effort): only if runner history is present for this plot run (set externally)
        # Here: we leave it empty; _apply_square_ranges will already keep view sane.
        srcs["poly"].data = dict(xs=[], ys=[])

        # label
        try:
            area = float(metrics_row["bbox_area"])
            hpwl = float(metrics_row["hpwl"])
            ov = float(metrics_row["overlap"])
            bd = float(metrics_row["boundary_violation"])
            text = f"{label} | area={area:.4g} hpwl={hpwl:.4g} ov={ov:.3g} bd={bd:.3g}"
        except Exception:
            text = label

        srcs["label"].data = dict(x=[5.0], y=[5.0], text=[text])

    def _apply_square_ranges(self, fig, metrics_row):
        # Keep plot aspect ratio 1 by using max(bbox_w, bbox_h, canvas_w, canvas_h) if available.
        # Fallback: bbox-based.
        max_dim = 100.0
        try:
            bw = float(metrics_row["bbox_w"])
            bh = float(metrics_row["bbox_h"])
            max_dim = max(max_dim, bw, bh)
        except Exception:
            pass
        fig.x_range.start, fig.x_range.end = 0.0, max_dim
        fig.y_range.start, fig.y_range.end = 0.0, max_dim

    # ------------------------- JSON extraction -------------------------

    def _extract_dims(self, blk_json, block_order, var_list):
        wh = []
        for i, k in enumerate(block_order):
            variants = blk_json[k]
            vi = int(var_list[i]) if i < len(var_list) else 0
            vi = max(0, min(vi, len(variants) - 1))
            v = variants[vi]
            wh.append([float(v.get("width", 1.0)), float(v.get("height", 1.0))])
        return np.asarray(wh, dtype=np.float64)

    def _extract_pins(self, blk_json, block_order, var_list):
        pins = []
        for bi, k in enumerate(block_order):
            variants = blk_json[k]
            vi = int(var_list[bi]) if bi < len(var_list) else 0
            vi = max(0, min(vi, len(variants) - 1))
            v = variants[vi]
            nets = v.get("nets", {}) or {}
            for net_name, pin_list in nets.items():
                for pi, pin in enumerate(pin_list):
                    box = pin.get("box", [0.0, 0.0])
                    ox = float(box[0]) if len(box) > 0 else 0.0
                    oy = float(box[1]) if len(box) > 1 else 0.0
                    # if width/height present in box, use them; else default small
                    pw = float(box[2]) if len(box) > 2 else 0.8
                    ph = float(box[3]) if len(box) > 3 else 0.8
                    pins.append({
                        "block_i": bi,
                        "ox": ox,
                        "oy": oy,
                        "w": pw,
                        "h": ph,
                        "id": f"{net_name}:{pi}",
                    })
        return pins

    def _write_tmp_json(self, prefix, obj):
        fd, path = tempfile.mkstemp(prefix=prefix, suffix=".json")
        os.close(fd)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(obj, f, indent=2)
        return path

    def _metric_field_name(self, metric_enum):
        # Must match pybind structured dtype field names
        mapping = {
            pe.Metric.bbox_area: "bbox_area",
            pe.Metric.bbox_aspect: "bbox_aspect",
            pe.Metric.hpwl: "hpwl",
            pe.Metric.overlap: "overlap",
            pe.Metric.boundary_violation: "boundary_violation",
            pe.Metric.aspect_ratio_violation: "aspect_ratio_violation",
            pe.Metric.dead_space_area: "dead_space_area",
            pe.Metric.symmetry_violation: "symmetry_violation",
            pe.Metric.symmetry_violation_v: "symmetry_violation_v",
            pe.Metric.symmetry_violation_h: "symmetry_violation_h",
            pe.Metric.augmented_objective: "augmented_objective",
        }
        return mapping.get(metric_enum, "augmented_objective")

