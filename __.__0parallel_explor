std::vector<std::size_t> ParallelExplorationRunner::top_history_run_ids() const
{
  std::lock_guard<std::mutex> lk(top_mu_);
  std::vector<std::size_t> out;
  out.reserve(top_history_.size());
  for(const auto& e : top_history_) out.push_back(e.run_id);
  return out;
}

std::vector<std::size_t> ParallelExplorationRunner::top_best_run_ids(std::size_t k) const
{
  std::lock_guard<std::mutex> lk(top_mu_);
  const std::size_t n = std::min<std::size_t>(k, top_history_.size());
  std::vector<std::size_t> out;
  out.reserve(n);
  for(std::size_t i = 0; i < n; ++i) out.push_back(top_history_[i].run_id);
  return out;
}

const double* ParallelExplorationRunner::run_final_coords_data(std::size_t run_id) const
{
  auto st = mon_[run_id].state.load(std::memory_order_acquire);
  if(st != STATE_COMPLETED) throw std::runtime_error("run not completed");

  if(num_blocks_ == 0) throw std::runtime_error("num_blocks_ not initialized");
  const std::size_t stride = 2 * num_blocks_;
  if(final_coords_flat_.empty()) throw std::runtime_error("final_coords_flat_ not allocated");
  if(run_id * stride + stride > final_coords_flat_.size()) throw std::runtime_error("run_final_coords_data OOB");

  return final_coords_flat_.data() + run_id * stride;
}

const Metrics& ParallelExplorationRunner::run_final_metrics(std::size_t run_id) const
{
  auto st = mon_[run_id].state.load(std::memory_order_acquire);
  if(st != STATE_COMPLETED) throw std::runtime_error("run not completed");
  return final_metrics_.at(run_id);
}

const Metrics& ParallelExplorationRunner::run_best_metrics(std::size_t run_id) const
{
  auto st = mon_[run_id].state.load(std::memory_order_acquire);
  if(st != STATE_COMPLETED) throw std::runtime_error("run not completed");
  return best_metrics_.at(run_id);
}

