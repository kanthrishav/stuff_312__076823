In HistoryStore, immediately after the existing push(...) method ends (right after ++iter_count_;), I inserted a new method:

void compact_to_best_iteration(){
  if(max_iters_ <= 1) return;
  if(iter_count_ == 0) {
    coords_.assign(2 * n_, 0.0);
    iter_metrics_.assign(1, Metrics{});
    polygon_coords_.assign(2 * DeadSpace::kMaxVerts, 0.0);
    polygon_counts_.assign(1, std::uint8_t(0));
    best_index_ = 0;
    iter_count_ = 1;
    max_iters_ = 1;
    return;
  }

  const std::size_t bi = (best_index_ < iter_count_) ? best_index_ : (iter_count_ - 1);
  const std::size_t off = bi * (2 * n_);

  std::vector<double> coords1(2 * n_, 0.0);
  if(!best_coords_.empty()) {
    coords1 = best_coords_;
  } else {
    std::memcpy(coords1.data(), coords_.data() + off, sizeof(double) * (2 * n_));
  }

  Metrics m = best_metrics_;
  m.iters = 0;

  std::vector<double> poly1(2 * DeadSpace::kMaxVerts, 0.0);
  std::uint8_t poly_n = 0;
  if(!polygon_counts_.empty() && !polygon_coords_.empty()) {
    poly_n = polygon_counts_[bi];
    const double* pxy = polygon_coords_.data() + (bi * 2 * DeadSpace::kMaxVerts);
    std::memcpy(poly1.data(), pxy, sizeof(double) * (2 * DeadSpace::kMaxVerts));
  }

  coords_.swap(coords1);
  iter_metrics_.assign(1, m);
  polygon_coords_.swap(poly1);
  polygon_counts_.assign(1, poly_n);

  best_coords_ = coords_;
  best_metrics_ = m;
  best_index_ = 0;
  best_obj_ = m.augmented_objective;
  iter_count_ = 1;
  max_iters_ = 1;
}


