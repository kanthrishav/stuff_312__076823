void ParallelVariantRunner::update_topk_and_maybe_compact_(std::size_t completed_run_id)
{
  const double obj = mon_[completed_run_id].final_best_obj.load(std::memory_order_relaxed);

  std::size_t evicted = static_cast<std::size_t>(-1);
  bool keep = false;

  {
    std::lock_guard<std::mutex> lk(topk_mu_);

    for(std::size_t i = 0; i < topk_.size(); ++i)
    {
      if(topk_[i].second == completed_run_id)
      {
        topk_.erase(topk_.begin() + static_cast<std::ptrdiff_t>(i));
        break;
      }
    }

    topk_.push_back({obj, completed_run_id});
    std::sort(topk_.begin(), topk_.end(),
              [](const auto& a, const auto& b){ return a.first < b.first; });

    if(topk_.size() > kKeepFullHistoryTopK)
    {
      evicted = topk_.back().second;
      topk_.pop_back();
    }

    for(const auto& p : topk_)
    {
      if(p.second == completed_run_id) { keep = true; break; }
    }
  }

  if(evicted != static_cast<std::size_t>(-1)) compact_run_history_keep_best_(evicted);
  if(!keep) compact_run_history_keep_best_(completed_run_id);
}

