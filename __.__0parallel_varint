		{
			coords_.clear();
			iter_metrics_.clear();
			polygon_coords_.clear();
			polygon_counts_.clear();
			max_iters_ = 0;
			best_index_ = 0;
			best_obj_ = std::numeric_limits<double>::infinity();
			best_metrics_ = Metrics{};
			best_coords_.clear();
			return;
		}

		const std::size_t keep_idx = (best_index_ < iter_count_) ? best_index_ : (iter_count_ - 1);

		std::vector<double> poly_xy(2 * DeadSpace::kMaxVerts, 0.0);
		std::uint8_t poly_n = 0;
		if(keep_idx < polygon_counts_.size())
		{
			poly_n = polygon_counts_[keep_idx];
			const double* src = polygon_coords_.data() + (keep_idx * 2 * DeadSpace::kMaxVerts);
			std::memcpy(poly_xy.data(), src, sizeof(double) * (2 * DeadSpace::kMaxVerts));
		}

		coords_.assign(best_coords_.begin(), best_coords_.end());
		iter_metrics_.assign(1, best_metrics_);
		polygon_coords_.assign(poly_xy.begin(), poly_xy.end());
		polygon_counts_.assign(1, poly_n);

		iter_count_ = 1;
		max_iters_ = 1;
		best_index_ = 0;
		best_obj_ = best_metrics_.augmented_objective;
	}

