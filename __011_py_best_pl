def _best_build_program() -> pe.SelectionProgram:
	pr = pe.SelectionProgram()
	pr.clear()
	pr.clear_objectives()

	obj_m = _best_metric_name_to_enum[best_obj_metric.value]
	obj_op = _best_objective_name_to_enum[best_obj_op.value]
	pr.add_objective(obj_m, obj_op, float(best_tie_eps.value))

	# Add enabled filters (single AND-clause)
	if bool(best_en_overlap.value):
		pr.add_filter(pe.Metric.overlap, pe.CompareOp.less_equal, float(best_eps_overlap.value), 0.0)
	if bool(best_en_boundary.value):
		pr.add_filter(pe.Metric.boundary_violation, pe.CompareOp.less_equal, float(best_eps_boundary.value), 0.0)
	if bool(best_en_aspect.value):
		pr.add_filter(pe.Metric.aspect_ratio_violation, pe.CompareOp.less_equal, float(best_eps_aspect.value), 0.0)
	if bool(best_en_sym.value):
		pr.add_filter(pe.Metric.symmetry_violation, pe.CompareOp.less_equal, float(best_eps_sym.value), 0.0)
	if bool(best_en_dead.value):
		pr.add_filter(pe.Metric.dead_space_area, pe.CompareOp.less_equal, float(best_eps_dead.value), 0.0)

	# If nothing matches, fall back to engine "best_index" (C++ global best)
	pr.fallback_policy = pe.FallbackPolicy.use_best_index
	return pr

def _best_center_canvas_from_metrics(mrec: Any) -> None:
	# Center view on bbox; keep padding so placement is clearly visible.
	cx = float(mrec["bbox_cx"])
	cy = float(mrec["bbox_cy"])
	bw = float(mrec["bbox_w"])
	bh = float(mrec["bbox_h"])

	pad = float(main_tab_canvas_buffer) + 0.15 * max(bw, bh, 1.0)
	half_x = max(0.6 * bw, 1.0) + pad
	half_y = max(0.6 * bh, 1.0) + pad

	canvas_fig.x_range.start = cx - half_x
	canvas_fig.x_range.end = cx + half_x
	canvas_fig.y_range.start = cy - half_y
	canvas_fig.y_range.end = cy + half_y

def _best_render_metrics_text(idx: int, mrec: Any) -> None:
	best_selected_metrics.object = (
		f"**Selected Best Placement**\n\n"
		f"- history_index: `{idx}`\n"
		f"- bbox_area: `{float(mrec['bbox_area']):.6g}`\n"
		f"- hpwl: `{float(mrec['hpwl']):.6g}`\n"
		f"- overlap: `{float(mrec['overlap']):.6g}`\n"
		f"- aspect_ratio_violation: `{float(mrec['aspect_ratio_violation']):.6g}`\n"
		f"- boundary_violation: `{float(mrec['boundary_violation']):.6g}`\n"
	)

def on_best_select_click(event) -> None:
	try:
		# Ensure history is loaded (needed for slider/canvas updates)
		if manager.run_coords is None or manager.run_W is None:
			manager._update_optim_values()

		pr = _best_build_program()
		idx = int(runner.select_best_index(pr))

		# Update slider first (drives main-canvas update via existing watcher)
		manager.iter_slider.value = idx

		# Center axes and render metrics from C++ metrics history (fast, zero-copy)
		mh = runner.metrics_history()
		mrec = mh[idx]
		_best_center_canvas_from_metrics(mrec)
		_best_render_metrics_text(idx, mrec)

		manager._update_status(f"idle (selected best index = {idx})")
	except Exception as e:
		manager._update_status(f"idle (best-select failed: {e})")

