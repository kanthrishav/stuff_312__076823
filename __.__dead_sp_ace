#pragma once
#include <cstdint>
#include <vector>
#include <unordered_map>
#include <cmath>
#include <algorithm>

class DeadSpacePolys
{
public:
    DeadSpacePolys() : cell_(1.0), W_(0.0), H_(0.0), rows_(0), cols_(0) {}

    void init(const double canvas_w, const double canvas_h, const double cell_size)
    {
        W_ = canvas_w;
        H_ = canvas_h;
        cell_ = std::max(1e-9, cell_size);
        cols_ = (std::int32_t)std::ceil(W_ / cell_);
        rows_ = (std::int32_t)std::ceil(H_ / cell_);
    }

    template<typename BlockT>
    void compute_polygons_AB(const BlockT* blocks, const std::size_t n,
                             const double bbox_minx, const double bbox_miny,
                             const double bbox_maxx, const double bbox_maxy,
                             std::vector<double>& A_xy, std::vector<std::uint32_t>& A_poly_off,
                             std::vector<double>& B_xy, std::vector<std::uint32_t>& B_poly_off) const
    {
        A_xy.clear(); A_poly_off.clear();
        B_xy.clear(); B_poly_off.clear();

        const double minx = std::max(0.0, bbox_minx);
        const double miny = std::max(0.0, bbox_miny);
        const double maxx = std::min(W_, bbox_maxx);
        const double maxy = std::min(H_, bbox_maxy);
        if (maxx <= minx || maxy <= miny) return;

        const std::int32_t by0 = clamp_row(miny);
        const std::int32_t by1 = clamp_row(maxy - 1e-12);
        const std::int32_t bx0 = clamp_col(minx);
        const std::int32_t bx1 = clamp_col(maxx - 1e-12);
        if (by1 < by0 || bx1 < bx0) return;

        const std::int32_t sub_rows = by1 - by0 + 1;
        const std::int32_t sub_cols = bx1 - bx0 + 1;

        // Envelope row spans
        std::vector<std::int32_t> row_min(sub_rows, 0x3fffffff);
        std::vector<std::int32_t> row_max(sub_rows, -1);

        // Occupancy mask for blocks in bbox region
        std::vector<std::uint8_t> occ((std::size_t)sub_rows * (std::size_t)sub_cols, 0);

        // Build row spans + occupancy
        for (std::size_t i = 0; i < n; ++i)
        {
            const double btm = blocks[i].Bottom();
            const double top = blocks[i].Top();
            const double lft = blocks[i].Left();
            const double rgt = blocks[i].Right();

            const double cb = std::max(miny, btm);
            const double ct = std::min(maxy, top);
            if (ct <= cb) continue;
            const double cl = std::max(minx, lft);
            const double cr = std::min(maxx, rgt);
            if (cr <= cl) continue;

            const std::int32_t r0g = clamp_row(cb);
            const std::int32_t r1g = clamp_row(ct - 1e-12);
            const std::int32_t c0g = clamp_col(cl);
            const std::int32_t c1g = clamp_col(cr - 1e-12);

            const std::int32_t r0 = r0g - by0;
            const std::int32_t r1 = r1g - by0;
            const std::int32_t c0 = c0g - bx0;
            const std::int32_t c1 = c1g - bx0;

            for (std::int32_t r = r0; r <= r1; ++r)
            {
                row_min[r] = std::min(row_min[r], c0);
                row_max[r] = std::max(row_max[r], c1);

                // mark occupancy cells (raster)
                const std::size_t base = (std::size_t)r * (std::size_t)sub_cols;
                for (std::int32_t c = c0; c <= c1; ++c)
                    occ[base + (std::size_t)c] = 1;
            }
        }

        // Build envelope mask
        std::vector<std::uint8_t> env((std::size_t)sub_rows * (std::size_t)sub_cols, 0);
        for (std::int32_t r = 0; r < sub_rows; ++r)
        {
            if (row_max[r] >= 0)
            {
                const std::int32_t l = std::max(0, row_min[r]);
                const std::int32_t u = std::min(sub_cols - 1, row_max[r]);
                const std::size_t base = (std::size_t)r * (std::size_t)sub_cols;
                for (std::int32_t c = l; c <= u; ++c)
                    env[base + (std::size_t)c] = 1;
            }
        }

        // A_mask = bbox_mask (all subgrid cells are inside bbox) minus envelope
        std::vector<std::uint8_t> A((std::size_t)sub_rows * (std::size_t)sub_cols, 0);
        for (std::size_t i = 0; i < A.size(); ++i) A[i] = (env[i] ? 0 : 1);

        // B_mask = envelope minus blocks
        std::vector<std::uint8_t> B((std::size_t)sub_rows * (std::size_t)sub_cols, 0);
        for (std::size_t i = 0; i < B.size(); ++i) B[i] = (env[i] && !occ[i]) ? 1 : 0;

        mask_to_polygons(A, sub_rows, sub_cols, bx0, by0, A_xy, A_poly_off);
        mask_to_polygons(B, sub_rows, sub_cols, bx0, by0, B_xy, B_poly_off);
    }

private:
    std::int32_t clamp_row(const double y) const noexcept
    {
        std::int32_t r = (std::int32_t)std::floor(y / cell_);
        if (r < 0) r = 0;
        if (r >= rows_) r = rows_ - 1;
        return r;
    }
    std::int32_t clamp_col(const double x) const noexcept
    {
        std::int32_t c = (std::int32_t)std::floor(x / cell_);
        if (c < 0) c = 0;
        if (c >= cols_) c = cols_ - 1;
        return c;
    }

    static std::uint64_t vid(const std::uint32_t x, const std::uint32_t y) noexcept
    {
        return (std::uint64_t(y) << 32) | std::uint64_t(x);
    }

    void mask_to_polygons(const std::vector<std::uint8_t>& mask,
                          const std::int32_t R, const std::int32_t C,
                          const std::int32_t bx0_global, const std::int32_t by0_global,
                          std::vector<double>& out_xy,
                          std::vector<std::uint32_t>& out_poly_off) const
    {
        out_poly_off.clear();
        out_poly_off.push_back(0);

        // boundary edges as directed map start->end
        std::unordered_map<std::uint64_t, std::uint64_t> next;
        next.reserve((std::size_t)R * (std::size_t)C * 2);

        auto inside = [&](std::int32_t r, std::int32_t c)->bool{
            return (r >= 0 && r < R && c >= 0 && c < C) ? (mask[(std::size_t)r*(std::size_t)C + (std::size_t)c] != 0) : false;
        };

        for (std::int32_t r = 0; r < R; ++r)
        {
            for (std::int32_t c = 0; c < C; ++c)
            {
                if (!inside(r,c)) continue;

                const std::uint32_t x0 = (std::uint32_t)(c);
                const std::uint32_t x1 = (std::uint32_t)(c + 1);
                const std::uint32_t y0 = (std::uint32_t)(r);
                const std::uint32_t y1 = (std::uint32_t)(r + 1);

                // Clockwise orientation: inside on RIGHT
                // top neighbor empty -> top edge: (x1,y1)->(x0,y1)
                if (!inside(r+1, c))
                    next[vid(x1,y1)] = vid(x0,y1);

                // bottom neighbor empty -> bottom edge: (x0,y0)->(x1,y0)
                if (!inside(r-1, c))
                    next[vid(x0,y0)] = vid(x1,y0);

                // left neighbor empty -> left edge: (x0,y0)->(x0,y1)
                if (!inside(r, c-1))
                    next[vid(x0,y0)] = vid(x0,y1);

                // right neighbor empty -> right edge: (x1,y1)->(x1,y0)
                if (!inside(r, c+1))
                    next[vid(x1,y1)] = vid(x1,y0);
            }
        }

        // trace loops
        std::unordered_map<std::uint64_t, std::uint8_t> used;
        used.reserve(next.size());

        for (auto& kv : next)
        {
            const std::uint64_t start = kv.first;
            if (used[start]) continue;

            // follow until we return or break
            std::uint64_t cur = start;
            const std::uint32_t poly_start = (std::uint32_t)out_xy.size();

            while (true)
            {
                used[cur] = 1;

                const std::uint32_t lx = (std::uint32_t)(cur & 0xffffffffu);
                const std::uint32_t ly = (std::uint32_t)(cur >> 32);

                const double wx = (double)(bx0_global + (std::int32_t)lx) * cell_;
                const double wy = (double)(by0_global + (std::int32_t)ly) * cell_;

                out_xy.push_back(wx);
                out_xy.push_back(wy);

                auto it = next.find(cur);
                if (it == next.end()) break;
                const std::uint64_t nxt = it->second;
                cur = nxt;

                if (cur == start) break;
                if (used[cur]) break;
            }

            // close polygon by repeating first vertex if at least 3 points
            const std::uint32_t poly_end = (std::uint32_t)out_xy.size();
            const std::uint32_t ncoords = poly_end - poly_start;
            if (ncoords >= 6)
            {
                out_xy.push_back(out_xy[poly_start + 0]);
                out_xy.push_back(out_xy[poly_start + 1]);
                out_poly_off.push_back((std::uint32_t)out_xy.size());
            }
            else
            {
                // discard tiny degenerate
                out_xy.resize(poly_start);
            }
        }

        if (out_poly_off.size() == 1)
            out_poly_off.push_back((std::uint32_t)out_xy.size());
    }

private:
    double cell_;
    double W_, H_;
    std::int32_t rows_, cols_;
};


