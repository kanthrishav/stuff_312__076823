#pragma once
#include <algorithm>
#include <cstdint>
#include <limits>
#include <vector>
#include <cmath>

class DeadSpaceFast
{
public:
    DeadSpaceFast()
    : cell_(1.0), rows_(0), cols_(0), W_(0.0), H_(0.0)
    {}

    void init(const double canvas_w, const double canvas_h, const double cell_size)
    {
        W_ = canvas_w;
        H_ = canvas_h;
        cell_ = std::max(1e-9, cell_size);
        cols_ = static_cast<std::int32_t>(std::ceil(W_ / cell_));
        rows_ = static_cast<std::int32_t>(std::ceil(H_ / cell_));

        row_min_.assign(rows_, kINF);
        row_max_.assign(rows_, -1);
    }

    double cell_size() const noexcept { return cell_; }

    // Extremely fast scalar areas only (no polygon extraction here)
    // Requires:
    // - bbox (minx,miny,maxx,maxy)
    // - block rectangles (left,right,bottom,top) from positions
    // Produces:
    // - areaA = bbox minus envelope
    // - areaB = envelope minus sum_block_area (assuming no overlap)
    template<typename BlockT>
    void compute_areas_fast(const BlockT* blocks, const std::size_t n,
                            const double bbox_minx, const double bbox_miny,
                            const double bbox_maxx, const double bbox_maxy,
                            const double sum_block_area,
                            double& outA, double& outB) const
    {
        outA = 0.0;
        outB = 0.0;

        // clamp bbox to canvas
        const double minx = std::max(0.0, bbox_minx);
        const double miny = std::max(0.0, bbox_miny);
        const double maxx = std::min(W_, bbox_maxx);
        const double maxy = std::min(H_, bbox_maxy);

        if (maxx <= minx || maxy <= miny) return;

        const std::int32_t by0 = clamp_row(miny);
        const std::int32_t by1 = clamp_row(maxy - 1e-12);
        const std::int32_t bx0 = clamp_col(minx);
        const std::int32_t bx1 = clamp_col(maxx - 1e-12);

        if (by1 < by0 || bx1 < bx0) return;

        // Reset only used rows
        for (std::int32_t r = by0; r <= by1; ++r)
        {
            row_min_[r] = kINF;
            row_max_[r] = -1;
        }

        // Build row-span envelope by scanning blocks
        for (std::size_t i = 0; i < n; ++i)
        {
            const double btm = blocks[i].Bottom();
            const double top = blocks[i].Top();
            const double lft = blocks[i].Left();
            const double rgt = blocks[i].Right();

            // clamp block to bbox
            const double cb = std::max(miny, btm);
            const double ct = std::min(maxy, top);
            if (ct <= cb) continue;

            const double cl = std::max(minx, lft);
            const double cr = std::min(maxx, rgt);
            if (cr <= cl) continue;

            const std::int32_t r0 = clamp_row(cb);
            const std::int32_t r1 = clamp_row(ct - 1e-12);
            const std::int32_t c0 = clamp_col(cl);
            const std::int32_t c1 = clamp_col(cr - 1e-12);

            for (std::int32_t r = r0; r <= r1; ++r)
            {
                row_min_[r] = std::min(row_min_[r], c0);
                row_max_[r] = std::max(row_max_[r], c1);
            }
        }

        const std::int32_t bbox_w_cells = (bx1 - bx0 + 1);
        std::int64_t A_cells = 0;
        std::int64_t Env_cells = 0;

        for (std::int32_t r = by0; r <= by1; ++r)
        {
            if (row_max_[r] >= 0)
            {
                const std::int32_t l = std::max(bx0, row_min_[r]);
                const std::int32_t u = std::min(bx1, row_max_[r]);
                if (u >= l)
                {
                    const std::int32_t env_w = (u - l + 1);
                    Env_cells += env_w;
                    A_cells += (bbox_w_cells - env_w);
                }
                else
                {
                    // row had blocks but after clamp none remain
                    A_cells += bbox_w_cells;
                }
            }
            else
            {
                // no blocks in this row -> envelope empty -> entire bbox row is Area A
                A_cells += bbox_w_cells;
            }
        }

        const double cell_area = cell_ * cell_;
        const double env_area = static_cast<double>(Env_cells) * cell_area;
        outA = static_cast<double>(A_cells) * cell_area;

        // Area B defined only when union area ~ sum_block_area (no overlaps)
        outB = std::max(0.0, env_area - sum_block_area);
    }

private:
    static const std::int32_t kINF = 0x3fffffff;

    std::int32_t clamp_row(const double y) const noexcept
    {
        std::int32_t r = static_cast<std::int32_t>(std::floor(y / cell_));
        if (r < 0) r = 0;
        if (r >= rows_) r = rows_ - 1;
        return r;
    }

    std::int32_t clamp_col(const double x) const noexcept
    {
        std::int32_t c = static_cast<std::int32_t>(std::floor(x / cell_));
        if (c < 0) c = 0;
        if (c >= cols_) c = cols_ - 1;
        return c;
    }

private:
    double cell_;
    std::int32_t rows_, cols_;
    double W_, H_;

    // mutable to allow compute_areas_fast to be const without allocations
    mutable std::vector<std::int32_t> row_min_;
    mutable std::vector<std::int32_t> row_max_;
};


