class DeadSpaceSegmenter
{
public:
    DeadSpaceSegmenter()
    : n_(0), active_count_(0), top_(nullptr), bot_(nullptr)
    {}

    void init(const std::size_t n)
    {
        n_ = n;
        events_.resize(2 * n_);
        active_.assign(n_, 0);
        top_heap_.reserve(n_);
        bot_heap_.reserve(n_);
    }

    // Computes AreaB = envelope area; AreaA = bbox_area - AreaB; DeadB = AreaB - total_area (only if overlap ~ 0).
    // Inputs are arrays of rect edges for this iteration.
    void compute(const double* L, const double* R, const double* B, const double* T,
                 const double bbox_area,
                 const double total_rect_area,
                 const bool allow_deadspace, // typically (overlap <= eps)
                 double& out_area_A,
                 double& out_area_B,
                 double& out_dead_A,
                 double& out_dead_B)
    {
        // If deadspace is not allowed (e.g. overlap exists), keep it 0 to avoid tradeoff and extra cost.
        if (!allow_deadspace || n_ == 0)
        {
            out_area_A = 0.0;
            out_area_B = 0.0;
            out_dead_A = 0.0;
            out_dead_B = 0.0;
            return;
        }

        // bind pointers for heap comparisons
        top_ = T;
        bot_ = B;

        // Build events (2 per rect)
        for (std::size_t i = 0; i < n_; ++i)
        {
            events_[2*i + 0] = Event{ L[i], i, 0 }; // end=0? no, start flag stored separately below
            events_[2*i + 1] = Event{ R[i], i, 1 };
            // We'll interpret: kind=0 -> start, kind=1 -> end (and sort end before start at same x)
            events_[2*i + 0].kind = 0; // start at L
            events_[2*i + 1].kind = 1; // end at R
            active_[i] = 0;
        }

        // Sort by x; for same x process END before START to implement [L,R) activity.
        std::sort(events_.begin(), events_.end(),
                  [](const Event& a, const Event& b)
                  {
                      if (a.x < b.x) return true;
                      if (a.x > b.x) return false;
                      return a.kind > b.kind; // end(kind=1) before start(kind=0)
                  });

        // reset heaps
        top_heap_.clear();
        bot_heap_.clear();
        active_count_ = 0;

        double envelope_area = 0.0;

        std::size_t k = 0;
        while (k < events_.size())
        {
            const double x = events_[k].x;

            // Apply all events at x (end first because of sorting)
            while (k < events_.size() && events_[k].x == x)
            {
                const std::size_t idx = events_[k].idx;
                const unsigned char kind = events_[k].kind;

                if (kind == 1)
                {
                    // END at R: deactivate
                    if (active_[idx])
                    {
                        active_[idx] = 0;
                        --active_count_;
                    }
                }
                else
                {
                    // START at L: activate
                    if (!active_[idx])
                    {
                        active_[idx] = 1;
                        ++active_count_;
                        push_top_(idx);
                        push_bot_(idx);
                    }
                }
                ++k;
            }

            if (k >= events_.size()) break;

            const double next_x = events_[k].x;
            const double dx = next_x - x;

            if (dx > 0.0 && active_count_ > 0)
            {
                // Clean invalid heap tops
                clean_top_();
                clean_bot_();

                if (!top_heap_.empty() && !bot_heap_.empty())
                {
                    const double topv = top_[top_heap_.front()];
                    const double botv = bot_[bot_heap_.front()];
                    const double h = (topv > botv) ? (topv - botv) : 0.0;
                    envelope_area += dx * h;
                }
            }
        }

        // AreaB is the envelope
        out_area_B = envelope_area;

        // AreaA is bbox outside the envelope
        out_area_A = (bbox_area > envelope_area) ? (bbox_area - envelope_area) : 0.0;

        // Dead space
        out_dead_A = out_area_A;

        const double deadB = envelope_area - total_rect_area;
        out_dead_B = (deadB > 0.0) ? deadB : 0.0;
    }

private:
    class Event
    {
    public:
        double x;
        std::size_t idx;
        unsigned char kind; // 0=start, 1=end
    };

    std::size_t n_;
    std::size_t active_count_;

    std::vector<Event> events_;
    std::vector<unsigned char> active_;

    // heaps store indices; heap order depends on bound top_/bot_ pointers
    std::vector<std::size_t> top_heap_; // max heap by top_
    std::vector<std::size_t> bot_heap_; // min heap by bot_ (implemented via comparator)

    const double* top_;
    const double* bot_;

    void push_top_(const std::size_t idx)
    {
        top_heap_.push_back(idx);
        std::push_heap(top_heap_.begin(), top_heap_.end(),
                       [this](std::size_t a, std::size_t b)
                       {
                           return top_[a] < top_[b]; // max heap
                       });
    }

    void push_bot_(const std::size_t idx)
    {
        bot_heap_.push_back(idx);
        std::push_heap(bot_heap_.begin(), bot_heap_.end(),
                       [this](std::size_t a, std::size_t b)
                       {
                           return bot_[a] > bot_[b]; // min heap
                       });
    }

    void clean_top_()
    {
        while (!top_heap_.empty())
        {
            const std::size_t idx = top_heap_.front();
            if (active_[idx]) break;
            std::pop_heap(top_heap_.begin(), top_heap_.end(),
                          [this](std::size_t a, std::size_t b)
                          {
                              return top_[a] < top_[b];
                          });
            top_heap_.pop_back();
        }
    }

    void clean_bot_()
    {
        while (!bot_heap_.empty())
        {
            const std::size_t idx = bot_heap_.front();
            if (active_[idx]) break;
            std::pop_heap(bot_heap_.begin(), bot_heap_.end(),
                          [this](std::size_t a, std::size_t b)
                          {
                              return bot_[a] > bot_[b];
                          });
            bot_heap_.pop_back();
        }
    }
};

