import sys
from pathlib import Path

import panel as pn
from bokeh.plotting import figure
from bokeh.models import ColumnDataSource, Slider, Div

pn.extension()

# Ensure module import works in-place (adjust name to your built module)
ROOT = Path(__file__).resolve().parents[1]
BUILD_REL = ROOT / "build" / "Release"
if BUILD_REL.exists():
    sys.path.insert(0, str(BUILD_REL))

import placement_engine_py as pe  # <-- change if your module name differs


def _flatten_polys(xy, off):
    """
    xy: flat [x0,y0,x1,y1,...]
    off: [start0, start1, ...] offsets into xy (in doubles, not points) - from C++
    returns xs_list, ys_list for bokeh.patches
    """
    xs_list = []
    ys_list = []
    if xy is None or off is None or len(off) < 2:
        return xs_list, ys_list

    for i in range(len(off) - 1):
        a = int(off[i])
        b = int(off[i + 1])
        seg = xy[a:b]
        if len(seg) < 6:
            continue
        xs = seg[0::2].tolist()
        ys = seg[1::2].tolist()
        xs_list.append(xs)
        ys_list.append(ys)
    return xs_list, ys_list


def make_app(jPars_path: str, jBlock_path: str):
    # Run optimization
    runner = pe.Runner()
    runner.set_files(jPars_path, jBlock_path)  # adjust to your API
    runner.execute()
    pl = runner.plptr()

    iters = pl.iter_count()
    n = pl.num_blocks()

    # Canvas
    cfg = pl.config_dict()  # adjust to your API; else parse json in python
    canvas_w = float(cfg["expected_params"]["canvas"]["width"])
    canvas_h = float(cfg["expected_params"]["canvas"]["height"])

    p = figure(
        title="Blocks + BBox + Deadspace (A and B)",
        x_range=(0, canvas_w),
        y_range=(0, canvas_h),
        width=900,
        height=700,
        match_aspect=True,
        tools="pan,wheel_zoom,reset"
    )

    # Canvas boundary
    canvas_src = ColumnDataSource(dict(cx=[canvas_w/2], cy=[canvas_h/2], w=[canvas_w], h=[canvas_h]))
    p.rect(x="cx", y="cy", width="w", height="h", source=canvas_src, fill_alpha=0.0, line_width=3)

    # Blocks source
    rect_src = ColumnDataSource(dict(cx=[], cy=[], w=[], h=[]))
    p.rect(x="cx", y="cy", width="w", height="h", source=rect_src, fill_alpha=0.25, line_width=2)

    # BBox source
    bbox_src = ColumnDataSource(dict(cx=[0.0], cy=[0.0], w=[0.0], h=[0.0]))
    p.rect(x="cx", y="cy", width="w", height="h", source=bbox_src, fill_alpha=0.0, line_width=3)

    # Deadspace A polygons (bbox - envelope): draw as patches
    A_src = ColumnDataSource(dict(xs=[], ys=[]))
    p.patches(xs="xs", ys="ys", source=A_src, fill_alpha=0.12, line_alpha=0.9)

    # Deadspace B polygons (envelope - blocks): draw as patches
    B_src = ColumnDataSource(dict(xs=[], ys=[]))
    p.patches(xs="xs", ys="ys", source=B_src, fill_alpha=0.12, line_alpha=0.9)

    info = Div(text="", width=900)

    slider = Slider(start=0, end=max(0, iters - 1), value=0, step=1, title="Iteration")

    # widths/heights constant
    W = pl.block_widths()   # list/np array
    H = pl.block_heights()

    def update(i: int):
        xy = pl.iter_xy(i)  # flat [x0,y0,x1,y1,...]
        cx = [float(xy[2*k+0]) for k in range(n)]
        cy = [float(xy[2*k+1]) for k in range(n)]
        rect_src.data = dict(cx=cx, cy=cy, w=[float(W[k]) for k in range(n)], h=[float(H[k]) for k in range(n)])

        m = pl.iter_metrics(i)
        bbox_src.data = dict(cx=[m["bbox_cx"]], cy=[m["bbox_cy"]], w=[m["bbox_w"]], h=[m["bbox_h"]])

        polys = pl.deadspace_polygons_at(i)
        A_xy = polys["A_xy"]
        A_off = polys["A_off"]
        B_xy = polys["B_xy"]
        B_off = polys["B_off"]

        A_xs, A_ys = _flatten_polys(A_xy, A_off)
        B_xs, B_ys = _flatten_polys(B_xy, B_off)
        A_src.data = dict(xs=A_xs, ys=A_ys)
        B_src.data = dict(xs=B_xs, ys=B_ys)

        info.text = (
            f"<b>iter={i}</b> | aug={m['augmented_objective']:.6g} | "
            f"area={m['bbox_area']:.6g} | hpwl={m['hpwl']:.6g} | "
            f"overlap={m['overlap']:.6g} | boundary={m['boundary_violation']:.6g} | "
            f"aspect={m['aspect_ratio_violation']:.6g} | "
            f"deadA={m.get('deadspace_A', 0.0):.6g} | deadB={m.get('deadspace_B', 0.0):.6g}"
        )

    update(0)

    def _on_change(event):
        update(int(event.new))

    slider.on_change("value", _on_change)

    return pn.Column(info, slider, p)


def _get_args():
    # panel serve script.py --args jPars.json jBlock.json
    a = list(pn.state.argv) if pn.state.argv else []
    if len(a) >= 2:
        return a[0], a[1]
    return "jPars.json", "jBlock.json"


jpars, jblock = _get_args()
app = make_app(jpars, jblock)
