struct SlicingDecoder {
  struct Node{
    int left=-1, right=-1;
    int block=-1;          // leaf if >=0
    std::uint8_t op=0;     // 0 leaf, 1 H, 2 V
    double w=0,h=0;
    double x=0,y=0;
  };

  std::size_t n=0;
  std::vector<Node> nodes;
  std::vector<int> st;
  std::vector<int> leafNodeIdx; // leafNodeIdx[block]=node

  void init(std::size_t n_){
    n=n_;
    nodes.resize(2*n-1);
    st.reserve(2*n);
    leafNodeIdx.assign(n, -1);
  }

  // perm: [0..n-1], ops: length n-1, 0=H,1=V
  void decode(const int* perm, const std::uint8_t* ops,
              const double* W, const double* H,
              double* out_xy /*2n*/) {

    std::size_t node_cnt = 0;
    st.clear();

    // leaves
    for(std::size_t i=0;i<n;++i){
      const int b = perm[i];
      Node& nd = nodes[node_cnt];
      nd.left = nd.right = -1;
      nd.block = b;
      nd.op = 0;
      nd.w = W[static_cast<std::size_t>(b)];
      nd.h = H[static_cast<std::size_t>(b)];
      leafNodeIdx[static_cast<std::size_t>(b)] = static_cast<int>(node_cnt);
      st.push_back(static_cast<int>(node_cnt));
      ++node_cnt;
    }

    // left-deep valid slicing: apply all ops at end
    for(std::size_t k=0;k<n-1;++k){
      const int r = st.back(); st.pop_back();
      const int l = st.back(); st.pop_back();
      Node& nd = nodes[node_cnt];
      nd.left = l;
      nd.right = r;
      nd.block = -1;
      nd.op = ops[k] ? 2 : 1; // 1=H,2=V
      // compute size
      const Node& L = nodes[static_cast<std::size_t>(l)];
      const Node& R = nodes[static_cast<std::size_t>(r)];
      if(nd.op == 1){ // H: stack vertically
        nd.w = std::max(L.w, R.w);
        nd.h = L.h + R.h;
      } else { // V
        nd.w = L.w + R.w;
        nd.h = std::max(L.h, R.h);
      }
      st.push_back(static_cast<int>(node_cnt));
      ++node_cnt;
    }

    const int root = st.back();

    // assign coordinates (preorder)
    auto place = [&](auto&& self, int u, double x0, double y0) -> void {
      Node& nd = nodes[static_cast<std::size_t>(u)];
      nd.x = x0; nd.y = y0;
      if(nd.op == 0) return;
      Node& L = nodes[static_cast<std::size_t>(nd.left)];
      Node& R = nodes[static_cast<std::size_t>(nd.right)];
      if(nd.op == 1){ // H: R above L
        self(self, nd.left,  x0, y0);
        self(self, nd.right, x0, y0 + L.h);
      } else { // V: R right of L
        self(self, nd.left,  x0, y0);
        self(self, nd.right, x0 + L.w, y0);
      }
    };
    place(place, root, 0.0, 0.0);

    for(std::size_t b=0;b<n;++b){
      const int leaf = leafNodeIdx[b];
      const Node& nd = nodes[static_cast<std::size_t>(leaf)];
      out_xy[2*b + 0] = nd.x + 0.5*W[b];
      out_xy[2*b + 1] = nd.y + 0.5*H[b];
    }
  }
};

7) SA solvers (Sequence-pair / B* / Slicing)

Add new file: src/sa_solvers.hpp (or in your placement.cpp)

#pragma once
#include <random>
#include <cmath>
#include <numeric>

#include "seqpair.hpp"
#include "bstar.hpp"
#include "slicing.hpp"

struct SASolvers {

  static inline double temp_geometric(double t0, double t1, std::size_t i, std::size_t steps){
    if(steps <= 1) return t1;
    const double a = static_cast<double>(i) / static_cast<double>(steps - 1);
    return t0 * std::pow(t1 / t0, a);
  }

  static void solve_sequence_pair(LayoutEvaluator& eval, HistoryStore& store,
                                  std::uint64_t seed,
                                  std::size_t steps, double t0, double t1){

    const std::size_t n = eval.num_rects();
    SequencePairDecoder dec; dec.init(n);

    std::vector<int> P(n), Q(n);
    std::iota(P.begin(), P.end(), 0);
    std::iota(Q.begin(), Q.end(), 0);

    std::mt19937_64 rng(seed);
    std::shuffle(P.begin(), P.end(), rng);
    std::shuffle(Q.begin(), Q.end(), rng);

    std::uniform_int_distribution<int> pick_idx(0, static_cast<int>(n-1));
    std::uniform_real_distribution<double> ur(0.0, 1.0);

    std::vector<double> xy(2*n, 0.0);
    dec.decode(P.data(), Q.data(), eval.WVec().data(), eval.HVec().data(), xy.data());
    Metrics cur = eval.compute_all_xy(xy.data(), 0);
    store.push_raw(xy.data(), 2*n, cur);

    for(std::size_t it=1; it<=steps; ++it){
      const double T = temp_geometric(t0, t1, it, steps);

      // neighbor: swap in P or Q
      const bool swapP = (ur(rng) < 0.5);
      int a = pick_idx(rng), b = pick_idx(rng);
      if(a == b) b = (b+1) % static_cast<int>(n);

      if(swapP) std::swap(P[static_cast<std::size_t>(a)], P[static_cast<std::size_t>(b)]);
      else      std::swap(Q[static_cast<std::size_t>(a)], Q[static_cast<std::size_t>(b)]);

      dec.decode(P.data(), Q.data(), eval.WVec().data(), eval.HVec().data(), xy.data());
      Metrics nxt = eval.compute_all_xy(xy.data(), it);

      const double dE = (nxt.augmented_objective - cur.augmented_objective);
      bool accept = (dE <= 0.0);
      if(!accept && T > 0.0){
        const double p = std::exp(-dE / T);
        accept = (ur(rng) < p);
      }

      if(accept){
        cur = nxt;
        store.push_raw(xy.data(), 2*n, cur);
      } else {
        // revert
        if(swapP) std::swap(P[static_cast<std::size_t>(a)], P[static_cast<std::size_t>(b)]);
        else      std::swap(Q[static_cast<std::size_t>(a)], Q[static_cast<std::size_t>(b)]);
      }
    }
  }

  static void solve_bstar(LayoutEvaluator& eval, HistoryStore& store,
                          std::uint64_t seed,
                          std::size_t steps, double t0, double t1){

    const std::size_t n = eval.num_rects();
    BStarDecoder dec; dec.init(n);

    // random tree topology + label permutation
    std::mt19937_64 rng(seed);
    std::uniform_int_distribution<int> pick_node(0, static_cast<int>(n-1));
    std::uniform_real_distribution<double> ur(0.0, 1.0);

    BStarTree t;
    t.root = 0;
    t.left.assign(n, -1);
    t.right.assign(n, -1);

    // build a random valid binary tree (very simple)
    for(std::size_t v=1; v<n; ++v){
      while(true){
        const int p = pick_node(rng) % static_cast<int>(v); // attach only to existing
        if(ur(rng) < 0.5){
          if(t.left[p] < 0){ t.left[p] = static_cast<int>(v); break; }
        } else {
          if(t.right[p] < 0){ t.right[p] = static_cast<int>(v); break; }
        }
      }
    }

    std::vector<double> xy(2*n, 0.0);
    dec.decode(t, eval.WVec().data(), eval.HVec().data(), xy.data());
    Metrics cur = eval.compute_all_xy(xy.data(), 0);
    store.push_raw(xy.data(), 2*n, cur);

    for(std::size_t it=1; it<=steps; ++it){
      const double T = temp_geometric(t0, t1, it, steps);

      // neighbor: swap two module IDs by swapping W/H association *implicitly* not possible here
      // so we do a topology swap: swap left children of two nodes (cheap and valid)
      int a = pick_node(rng), b = pick_node(rng);
      if(a == b) b = (b+1) % static_cast<int>(n);

      std::swap(t.left[static_cast<std::size_t>(a)], t.left[static_cast<std::size_t>(b)]);

      dec.decode(t, eval.WVec().data(), eval.HVec().data(), xy.data());
      Metrics nxt = eval.compute_all_xy(xy.data(), it);

      const double dE = nxt.augmented_objective - cur.augmented_objective;
      bool accept = (dE <= 0.0);
      if(!accept && T > 0.0){
        accept = (ur(rng) < std::exp(-dE / T));
      }

      if(accept){
        cur = nxt;
        store.push_raw(xy.data(), 2*n, cur);
      } else {
        std::swap(t.left[static_cast<std::size_t>(a)], t.left[static_cast<std::size_t>(b)]);
      }
    }
  }

  static void solve_slicing(LayoutEvaluator& eval, HistoryStore& store,
                            std::uint64_t seed,
                            std::size_t steps, double t0, double t1){

    const std::size_t n = eval.num_rects();
    SlicingDecoder dec; dec.init(n);

    std::vector<int> perm(n);
    std::iota(perm.begin(), perm.end(), 0);

    std::vector<std::uint8_t> ops(n>0? n-1:0, 0); // 0=H,1=V

    std::mt19937_64 rng(seed);
    std::shuffle(perm.begin(), perm.end(), rng);
    std::uniform_int_distribution<int> pick_idx(0, static_cast<int>(n-1));
    std::uniform_real_distribution<double> ur(0.0, 1.0);

    for(auto& op : ops) op = (ur(rng) < 0.5) ? 0 : 1;

    std::vector<double> xy(2*n, 0.0);
    dec.decode(perm.data(), ops.data(), eval.WVec().data(), eval.HVec().data(), xy.data());
    Metrics cur = eval.compute_all_xy(xy.data(), 0);
    store.push_raw(xy.data(), 2*n, cur);

    for(std::size_t it=1; it<=steps; ++it){
      const double T = temp_geometric(t0, t1, it, steps);

      const bool do_swap = (ur(rng) < 0.7);
      int a=0,b=0; std::uint8_t old=0;
      if(do_swap){
        a = pick_idx(rng); b = pick_idx(rng);
        if(a==b) b = (b+1) % static_cast<int>(n);
        std::swap(perm[static_cast<std::size_t>(a)], perm[static_cast<std::size_t>(b)]);
      } else if(!ops.empty()){
        a = static_cast<int>(std::uniform_int_distribution<int>(0, static_cast<int>(ops.size()-1))(rng));
        old = ops[static_cast<std::size_t>(a)];
        ops[static_cast<std::size_t>(a)] = (old ^ 1u);
      }

      dec.decode(perm.data(), ops.data(), eval.WVec().data(), eval.HVec().data(), xy.data());
      Metrics nxt = eval.compute_all_xy(xy.data(), it);

      const double dE = nxt.augmented_objective - cur.augmented_objective;
      bool accept = (dE <= 0.0);
      if(!accept && T > 0.0) accept = (ur(rng) < std::exp(-dE / T));

      if(accept){
        cur = nxt;
        store.push_raw(xy.data(), 2*n, cur);
      } else {
        // revert
        if(do_swap){
          std::swap(perm[static_cast<std::size_t>(a)], perm[static_cast<std::size_t>(b)]);
        } else if(!ops.empty()){
          ops[static_cast<std::size_t>(a)] = old;
        }
      }
    }
  }
};

8) Placement::execute(): select solver ONCE (fast)

Replace your Placement::execute() with:

// ===== PATCH: Placement::execute solver strategy =====
void execute(){
  Stopwatch sw;

  const OptimizerAlgo algo = parse_optimizer_algo(cfg_.optimizer.algorithm);

  // CP-SAT
  if(cfg_.formulation.kind == FormulationKind::CPSAT || algo == OptimizerAlgo::CPSAT){
#ifndef PLACEMENT_ENGINE_WITH_ORTOOLS
    throw std::runtime_error("CPSAT requested but OR-Tools support not built. "
                             "Build with -DPLACEMENT_ENGINE_WITH_ORTOOLS=ON and link OR-Tools.");
#else
    // TODO: OR-Tools CPSAT implementation (model non-overlap, canvas bounds, objective, etc.)
#endif
  }

  // Discrete SA formulations
  if(algo == OptimizerAlgo::SA){
    if(cfg_.formulation.kind == FormulationKind::SequencePair){
      SASolvers::solve_sequence_pair(evaluator_, store_, cfg_.optimizer.seed,
                                     cfg_.formulation.sa_steps, cfg_.formulation.sa_t0, cfg_.formulation.sa_t1);
    } else if(cfg_.formulation.kind == FormulationKind::BStarTree){
      SASolvers::solve_bstar(evaluator_, store_, cfg_.optimizer.seed,
                             cfg_.formulation.sa_steps, cfg_.formulation.sa_t0, cfg_.formulation.sa_t1);
    } else if(cfg_.formulation.kind == FormulationKind::SlicingTree){
      SASolvers::solve_slicing(evaluator_, store_, cfg_.optimizer.seed,
                               cfg_.formulation.sa_steps, cfg_.formulation.sa_t0, cfg_.formulation.sa_t1);
    } else {
      throw std::runtime_error("SA requested but formulation is not a discrete structure.");
    }
    runtime_s_ = sw.Seconds();
    optimized_ = true;
    return;
  }

  // Continuous DE (penalty / reduced_space)
  if(algo == OptimizerAlgo::DE){
    arma::arma_rng::set_seed(static_cast<arma::uword>(cfg_.optimizer.seed));
    LayoutObjective obj(&evaluator_);
    arma::mat x = evaluator_.initial_point();

    IterationCallback cb;
    cb.init(&evaluator_, &store_, cfg_.optimizer.stopping_criteria, cfg_.optimizer.stopping_value);

    const double F = 0.5 * (cfg_.optimizer.mutation_min + cfg_.optimizer.mutation_max);
    const double tol = (cfg_.optimizer.stopping_criteria == "target_objective") ? cfg_.optimizer.stopping_value : -1.0;

    ens::DE optimizer(cfg_.optimizer.pop_size, cfg_.optimizer.max_iter, cfg_.optimizer.recombination, F, tol);
    optimizer.Optimize(obj, x, cb);

    runtime_s_ = sw.Seconds();
    optimized_ = true;
    return;
  }

  throw std::runtime_error("Unknown optimizer.algorithm path.");
}
// ===== END PATCH =====

9) CP / CP-SAT (CPSAT) integration (optional build)

This is heavy and should not run through compute_all() iteration-by-iteration. It’s a solver strategy.

CMake toggle
option(PLACEMENT_ENGINE_WITH_ORTOOLS "Enable OR-Tools CPSAT solver" OFF)
if(PLACEMENT_ENGINE_WITH_ORTOOLS)
  add_definitions(-DPLACEMENT_ENGINE_WITH_ORTOOLS=1)
  # link OR-Tools here (package or FetchContent)
endif()

What CPSAT would model (when you enable it)

Variables: x_i, y_i (or integer grid scaled)

Non-overlap: disjunctive constraints for each pair (or use NoOverlap2D if available)

Boundary: 0 <= x_i - w_i/2 and x_i + w_i/2 <= W etc

Objective: minimize w_area*bbox_area + w_hpwl*hpwl (hpwl requires bbox of centers; can linearize with aux vars)

Important: CP-SAT is not compatible with your “10k iterations in 10ms” target; it’s a different class of solver used for global feasibility/optimality.

10) What stays micro-fast (your current requirement)

Penalty path: compute_all_xy() unchanged, and compute_all() is just eval_fn_(*this, x, iter) (one indirect call).

No string comparisons in evaluation.

Reduced-space adds only O(k) assignments to expand active variables (often reduces time because DE dimension shrinks).

Structural formulations are real implementations but inherently heavier than direct XY penalty evaluation (they’re discrete floorplanning). They run only when selected.

One critical note about varList

Your example varList length is 8, but blocks may be variable. For reduced-space to work correctly:

varList must be length 2*n (mask per coordinate), OR

you must define a convention (mask per block, mask x-only etc.) and expand it during parse.

If you want zero ambiguity, enforce: varList.size() == 2*blocks.size() at parse time (throw if mismatch).
