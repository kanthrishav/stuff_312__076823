// ===== PATCH B: JsonIO helpers =====
static inline FormulationKind parse_formulation_kind(const std::string& s){
  if(s == "penalty") return FormulationKind::Penalty;
  if(s == "sequence_pair") return FormulationKind::SequencePair;
  if(s == "bstar_tree") return FormulationKind::BStarTree;
  if(s == "slicing_tree") return FormulationKind::SlicingTree;
  if(s == "reduced_space") return FormulationKind::ReducedSpace;
  if(s == "cpsat") return FormulationKind::CPSAT;
  throw std::runtime_error("Unknown problem_formulation.type: " + s);
}

static inline OptimizerAlgo parse_optimizer_algo(const std::string& s){
  if(s == "DE") return OptimizerAlgo::DE;
  if(s == "SA") return OptimizerAlgo::SA;
  if(s == "CPSAT") return OptimizerAlgo::CPSAT;
  throw std::runtime_error("Unknown optimizer.algorithm: " + s);
}

static inline std::vector<std::uint8_t> parse_varList_01(const json& j){
  if(!j.contains("varList")) return {};
  const auto v = j.at("varList").get<std::vector<int>>();
  std::vector<std::uint8_t> out;
  out.reserve(v.size());
  for(int x : v) out.push_back(static_cast<std::uint8_t>(x != 0));
