6.1 Sequence-pair SA (Fenwick O(n log n) decode, no sorting)

Create new file: include/seqpair.hpp

#pragma once
#include <vector>
#include <algorithm>
#include <cstddef>
#include <cstdint>

struct FenwickMax {
  std::vector<double> bit;
  void init(std::size_t n){ bit.assign(n+1, 0.0); }
  void reset(){ std::fill(bit.begin(), bit.end(), 0.0); }
  inline void update(std::size_t idx0, double v){
    for(std::size_t i = idx0+1; i < bit.size(); i += i & (~i + 1)) bit[i] = std::max(bit[i], v);
  }
  inline double query(std::size_t idx0) const {
    double res = 0.0;
    for(std::size_t i = idx0+1; i > 0; i -= i & (~i + 1)) res = std::max(res, bit[i]);
    return res;
  }
};

struct SequencePairDecoder {
  std::size_t n = 0;
  std::vector<int> posQ;
  std::vector<double> xll, yll;
  FenwickMax fx, fy;

  void init(std::size_t n_){
    n = n_;
    posQ.assign(n, 0);
    xll.assign(n, 0.0);
    yll.assign(n, 0.0);
    fx.init(n);
    fy.init(n);
  }

  // P,Q are permutations of [0..n-1]
  inline void decode(const int* P, const int* Q,
                     const double* w, const double* h,
                     double* out_xy /*len=2n*/) {
    for(std::size_t k=0; k<n; ++k) posQ[ static_cast<std::size_t>(Q[k]) ] = static_cast<int>(k);

    fx.reset();
    for(std::size_t k=0; k<n; ++k){
      const int id = P[k];
      const std::size_t i = static_cast<std::size_t>(id);
      const std::size_t qpos = static_cast<std::size_t>(posQ[i]);
      const double base = fx.query(qpos);
      xll[i] = base;
      fx.update(qpos, base + w[i]);
    }

    // vertical: use reversed Q index => prefix query corresponds to "greater posQ"
    fy.reset();
    for(std::size_t k=0; k<n; ++k){
      const int id = P[k];
      const std::size_t i = static_cast<std::size_t>(id);
      const std::size_t rq = (n-1) - static_cast<std::size_t>(posQ[i]);
      const double base = fy.query(rq);
      yll[i] = base;
      fy.update(rq, base + h[i]);
    }

    for(std::size_t i=0; i<n; ++i){
      out_xy[2*i + 0] = xll[i] + 0.5*w[i];
      out_xy[2*i + 1] = yll[i] + 0.5*h[i];
    }
  }
};

6.2 B*-tree decode (segment tree O(n log n) skyline)

Create include/bstar.hpp

#pragma once
#include <vector>
#include <algorithm>
#include <cstddef>
#include <cstdint>

struct SegTreeAssignMax {
  std::size_t n = 0;
  std::vector<double> mx;
  std::vector<double> lazy;
  std::vector<std::uint8_t> has_lazy;

  void init(std::size_t n_){
    n = n_;
    mx.assign(4*n, 0.0);
    lazy.assign(4*n, 0.0);
    has_lazy.assign(4*n, 0);
  }

  inline void reset(){
    std::fill(mx.begin(), mx.end(), 0.0);
    std::fill(has_lazy.begin(), has_lazy.end(), 0);
  }

  inline void push(std::size_t p){
    if(!has_lazy[p]) return;
    const double v = lazy[p];
    const std::size_t l = p<<1, r = l|1;
    mx[l] = v; mx[r] = v;
    lazy[l] = v; lazy[r] = v;
    has_lazy[l] = has_lazy[r] = 1;
    has_lazy[p] = 0;
  }

  double query(std::size_t p, std::size_t tl, std::size_t tr, std::size_t l, std::size_t r){
    if(l>r) return 0.0;
    if(l==tl && r==tr) return mx[p];
    push(p);
    const std::size_t tm = (tl+tr)>>1;
    return std::max(query(p<<1, tl, tm, l, std::min(r, tm)),
                    query(p<<1|1, tm+1, tr, std::max(l, tm+1), r));
  }

  void assign(std::size_t p, std::size_t tl, std::size_t tr, std::size_t l, std::size_t r, double v){
    if(l>r) return;
    if(l==tl && r==tr){
      mx[p] = v;
      lazy[p] = v;
      has_lazy[p] = 1;
      return;
    }
    push(p);
    const std::size_t tm = (tl+tr)>>1;
    assign(p<<1, tl, tm, l, std::min(r, tm), v);
    assign(p<<1|1, tm+1, tr, std::max(l, tm+1), r, v);
    mx[p] = std::max(mx[p<<1], mx[p<<1|1]);
  }
};

struct BStarTree {
  int root = 0;
  std::vector<int> left;   // child to the right
  std::vector<int> right;  // child "above"
};

struct BStarDecoder {
  std::size_t n = 0;
  std::vector<double> xll, yll;
  std::vector<double> coords;
  std::vector<int> stack;
  SegTreeAssignMax seg;

  void init(std::size_t n_){
    n = n_;
    xll.assign(n, 0.0);
    yll.assign(n, 0.0);
    coords.reserve(2*n);
    stack.reserve(n);
  }

  inline void compute_x(const BStarTree& t, const double* w){
    // iterative DFS
    stack.clear();
    stack.push_back(t.root);
    xll[t.root] = 0.0;
    while(!stack.empty()){
      const int u = stack.back(); stack.pop_back();
      const int lc = t.left[u];
      const int rc = t.right[u];
      if(lc >= 0){
        xll[lc] = xll[u] + w[static_cast<std::size_t>(u)];
        stack.push_back(lc);
      }
      if(rc >= 0){
        xll[rc] = xll[u];
        stack.push_back(rc);
      }
    }
  }

  inline std::size_t idx_of(double x) const {
    return static_cast<std::size_t>(std::lower_bound(coords.begin(), coords.end(), x) - coords.begin());
  }

  void pack_dfs(const BStarTree& t, const double* w, const double* h, int u){
    const std::size_t iu0 = idx_of(xll[u]);
    const std::size_t iu1 = idx_of(xll[u] + w[static_cast<std::size_t>(u)]);
    const std::size_t L = iu0;
    const std::size_t R = (iu1>0? iu1-1 : 0);
    const double base = seg.query(1, 0, seg.n-1, L, R);
    yll[u] = base;
    seg.assign(1, 0, seg.n-1, L, R, base + h[static_cast<std::size_t>(u)]);

    const int lc = t.left[u];
    const int rc = t.right[u];
    if(lc >= 0) pack_dfs(t, w, h, lc);
    if(rc >= 0) pack_dfs(t, w, h, rc);
  }

  inline void decode(const BStarTree& t,
                     const double* w, const double* h,
                     double* out_xy /*2n*/) {
    compute_x(t, w);

    coords.clear();
    for(std::size_t i=0;i<n;++i){
      coords.push_back(xll[i]);
      coords.push_back(xll[i] + w[i]);
    }
    std::sort(coords.begin(), coords.end());
    coords.erase(std::unique(coords.begin(), coords.end()), coords.end());
    const std::size_t intervals = (coords.size() >= 2) ? (coords.size() - 1) : 1;
    seg.init(intervals);
    seg.reset();

    pack_dfs(t, w, h, t.root);

    for(std::size_t i=0; i<n; ++i){
      out_xy[2*i + 0] = xll[i] + 0.5*w[i];
      out_xy[2*i + 1] = yll[i] + 0.5*h[i];
    }
  }
};

