private:
	PE_ALWAYS_INLINE static double stable_sigmoid_01_(double z) noexcept
	{
		if(!std::isfinite(z)) z = 0.0;
		if(z >= 0.0)
		{
			const double e = std::exp(-z);
			return 1.0 / (1.0 + e);
		}
		const double e = std::exp(z);
		return e / (1.0 + e);
	}

	PE_ALWAYS_INLINE static std::uint32_t decode_variant_index_(const double z, const std::uint32_t k_limit) noexcept
	{
		if(k_limit <= 1u) return 0u;
		const double s = stable_sigmoid_01_(z);
		std::uint32_t idx = static_cast<std::uint32_t>(s * static_cast<double>(k_limit));
		if(idx >= k_limit) idx = k_limit - 1u;
		return idx;
	}










private:
	bool de_should_stop_() const noexcept
	{
		return run_token_ && run_token_->control && run_token_->control->stop_requested();
	}

	void de_control_gate_() const
	{
		if(run_token_ && run_token_->control)
		{
			run_token_->control->wait_if_paused();
		}
	}

	void de_publish_telemetry_(const std::size_t gen, const Metrics& m) const noexcept
	{
		if(run_token_ && run_token_->iter_counter && run_token_->telemetry_period != 0)
		{
			if((gen % run_token_->telemetry_period) == 0)
			{
				run_token_->iter_counter->store(static_cast<std::uint32_t>(gen), std::memory_order_relaxed);

				if(run_token_->last_bbox_area) run_token_->last_bbox_area->store(m.bbox_area, std::memory_order_relaxed);
				if(run_token_->last_hpwl) run_token_->last_hpwl->store(m.hpwl, std::memory_order_relaxed);
				if(run_token_->last_overlap) run_token_->last_overlap->store(m.overlap, std::memory_order_relaxed);
				if(run_token_->last_boundary_violation) run_token_->last_boundary_violation->store(m.boundary_violation, std::memory_order_relaxed);
				if(run_token_->last_aspect_violation) run_token_->last_aspect_violation->store(m.aspect_ratio_violation, std::memory_order_relaxed);
				if(run_token_->last_dead_space) run_token_->last_dead_space->store(m.dead_space_area, std::memory_order_relaxed);
				if(run_token_->last_symmetry) run_token_->last_symmetry->store(m.symmetry_violation, std::memory_order_relaxed);
				if(run_token_->last_objective) run_token_->last_objective->store(m.augmented_objective, std::memory_order_relaxed);
			}
		}
	}

	void de_store_generation_best_(const arma::subview_col<double>& best, const std::size_t gen)
	{
		const arma::mat best_copy = best;
		const double* best_ptr = best_copy.memptr();
		const Metrics m = evaluator_.compute_all(best_ptr, gen);

		if(!cfg_.expected.enable_variant_optimization)
		{
			store_.push_raw_xy(best_ptr, m, evaluator_.last_polygon_xy(), evaluator_.last_polygon_n(),
				evaluator_.w_, evaluator_.h_, cfg_.varList, false);
		}
		else
		{
			store_.push_raw_xy(best_ptr, m, evaluator_.last_polygon_xy(), evaluator_.last_polygon_n(),
				evaluator_.w_, evaluator_.h_, evaluator_.selected_variant, true);
		}

		de_publish_telemetry_(gen, m);
	}

	void run_de_optimized_(LayoutObjective& obj, arma::mat& x)
	{
		const auto& p = cfg_.optimizer.de;

		if(p.popsize < 3)
		{
			throw std::logic_error("DE::Optimize(): population size should be at least 3!");
		}

		const arma::uword dim = x.n_elem;

		arma::mat population(dim, p.popsize);
		arma::rowvec fitnessValues(p.popsize);

		// Match ensmallen DE population initialization: randn() around the starting point.
		arma::mat noise(dim, p.popsize);
		noise.randn();
		population.each_col() = x;
		population += noise;

		std::size_t bestIndex = 0;
		double bestFitness = std::numeric_limits<double>::infinity();

		for(std::size_t i = 0; i < p.popsize; ++i)
		{
			fitnessValues(i) = obj.Evaluate(population.col(i));
			if(fitnessValues(i) < bestFitness)
			{
				bestFitness = fitnessValues(i);
				bestIndex = i;
			}
		}

		// History semantics for DE: exactly one best candidate per generation.
		de_store_generation_best_(population.col(bestIndex), 0);
		x = population.col(bestIndex);

		double lastBestFitness = bestFitness;
		arma::mat bestElement = population.col(bestIndex);
		arma::mat mutant(dim, 1);
		arma::mat cr(dim, 1);

		for(std::size_t gen = 0; gen < p.maxgen; ++gen)
		{
			if(de_should_stop_()) break;
			de_control_gate_();
			if(de_should_stop_()) break;

			// Freeze generation champion for /best/1/bin, matching ensmallen's generation-level best usage.
			const arma::mat genBestElement = bestElement;

			for(std::size_t member = 0; member < p.popsize; ++member)
			{
				std::size_t l = 0, m = 0;
				do { l = arma::randi<arma::uword>(arma::distr_param(0, arma::uword(p.popsize - 1))); } while(l == member);
				do { m = arma::randi<arma::uword>(arma::distr_param(0, arma::uword(p.popsize - 1))); } while(m == member && m == l);

				mutant = genBestElement + p.differential_weight * (population.col(l) - population.col(m));

				cr.randu();
				for(arma::uword it = 0; it < dim; ++it)
				{
					if(cr[it] >= p.crossover_rate)
					{
						mutant[it] = population(it, member);
					}
				}

				const double mutantValue = obj.Evaluate(mutant);

				if(mutantValue < fitnessValues(member))
				{
					population.col(member) = mutant;
					fitnessValues(member) = mutantValue;
				}
			}

			bestIndex = 0;
			bestFitness = fitnessValues(0);
			for(std::size_t i = 1; i < p.popsize; ++i)
			{
				if(fitnessValues(i) < bestFitness)
				{
					bestFitness = fitnessValues(i);
					bestIndex = i;
				}
			}

			bestElement = population.col(bestIndex);
			de_store_generation_best_(population.col(bestIndex), gen + 1);
			x = population.col(bestIndex);

			if(cfg_.optimizer.common.stopping_criteria == "target_objective" &&
			   bestFitness <= cfg_.optimizer.common.stopping_criteria_value)
			{
				break;
			}

			if(std::abs(lastBestFitness - bestFitness) < p.tolerance)
			{
				break;
			}

			lastBestFitness = bestFitness;
		}
	}
