				<< "  Single usecase : placement_engine_app <jPar.json> <jBlock.json>\n"
				<< "  Multi usecase  : placement_engine_app --multi-usecase --input-dir <dir> --output-dir <dir> --max-parallel <N> [--overlap-threshold <value>]\n";
			return 1;
		}

		const std::string pathPars = std::string(argv[1]);
		const std::string pathQgen = std::string(argv[2]);
		Runner run;
		run.set_jPars_file(pathPars);
		run.set_jQgen_file(pathQgen);

		run.execute();
		return 0;
	}
	catch(const std::exception& e)
	{
		std::cerr << e.what() << std::endl;
		return 1;
	}
