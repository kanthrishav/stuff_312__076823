Got it. The key to keeping compute_all() as fast as it is now is:

Parse the constraint type once in JsonIO

Convert it to a pre-selected function pointer (or enum→function pointer) stored in ConstraintConfig

In compute_all() do zero string compares / zero switching, just:

compute metric (overlap/boundary/aspect)

penalty += weight * penalty_fn(metric)

Below are the exact code blocks to replace / exact insert locations based on the snippets you pasted.

CHANGE 1 — Add penalty type + penalty functions (INSERT)

File: where ConstraintConfig is defined (same header/cc)

INSERT this code immediately ABOVE:
class ConstraintConfig{

INSERT:
enum class PenaltyType : std::uint8_t
{
    SIMPLE_PENALTY = 0,          // weight * (v^2)
    BARRIER_PENALTY_EXP = 1,     // weight * (exp(v) - 1)
    BARRIER_PENALTY_LOG = 2      // weight * log(1 + v)
};

class PenaltyFns
{
public:
    static double SimpleSquare(const double v) noexcept
    {
        return v * v;
    }

    static double BarrierExp(const double v) noexcept
    {
        // 0 at v=0, grows fast; expm1 is stable for small v
        return std::expm1(v);
    }

    static double BarrierLog(const double v) noexcept
    {
        // 0 at v=0; slower growth than exp
        return std::log1p(v);
    }
};

