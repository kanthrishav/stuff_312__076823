class ConstraintConfig{
public:
    ConstraintConfig()
        : enabled(false),
          weight(0.0),
          normalization("no norm"),
          aggregation("sum"),
          type("simple_penalty"),
          penalty_type(PenaltyType::SIMPLE_PENALTY),
          penalty_fn(&PenaltyFns::SimpleSquare)
    {}

    bool enabled;
    double weight;
    std::string normalization;
    std::string aggregation;

    // Parsed from JSON
    std::string type;

    // Pre-decided at parse-time: NO selection needed in compute_all()
    PenaltyType penalty_type;
    double (*penalty_fn)(double);
};

CHANGE 3 — Fix parsing: parse type and bind penalty_fn once (REPLACE)

In your JsonIO class:

REPLACE this entire function:
static ConstraintConfig parse_constraint(const json& cnode, bool b_agg_norm){
    ConstraintConfig cc;
    cc.enabled = parse_bool_str(cnode.at("enabled").get<std::string>());
    cc.weight = cnode.at("penalty_weight").get<double>();
    cc.type = cnode.at("type").get<std::string>();
    if(b_agg_norm){
