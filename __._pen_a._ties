WITH this exact function:
static ConstraintConfig parse_constraint(const json& cnode, const bool b_agg_norm)
{
    ConstraintConfig cc;

    cc.enabled = parse_bool_str(cnode.at("enabled").get<std::string>());
    cc.weight  = cnode.at("penalty_weight").get<double>();

    // type is required
    cc.type = cnode.at("type").get<std::string>();

    // Bind penalty function ONCE (no string compares in compute_all)
    if (cc.type == "simple_penalty")
    {
        cc.penalty_type = PenaltyType::SIMPLE_PENALTY;
        cc.penalty_fn   = &PenaltyFns::SimpleSquare;
    }
    else if (cc.type == "barrier_penalty-exp")
    {
        cc.penalty_type = PenaltyType::BARRIER_PENALTY_EXP;
        cc.penalty_fn   = &PenaltyFns::BarrierExp;
    }
    else if (cc.type == "barrier_penalty-log")
    {
        cc.penalty_type = PenaltyType::BARRIER_PENALTY_LOG;
        cc.penalty_fn   = &PenaltyFns::BarrierLog;
    }
    else
    {
        throw std::runtime_error(
            "Invalid constraint type: " + cc.type +
            ". Allowed: simple_penalty | barrier_penalty-exp | barrier_penalty-log");
    }

    // normalization/aggregation only for per-rect / per-pair constraints
    if (b_agg_norm)
    {
        if (cnode.contains("normalization"))
            cc.normalization = cnode.at("normalization").get<std::string>();
        if (cnode.contains("aggregation"))
            cc.aggregation = cnode.at("aggregation").get<std::string>();
    }

    return cc;
}

