PYBIND11_MODULE(rect_place, m)
{
  m.doc() = "Fast rectangle placement optimizer (C++14, ensmallen, pybind11)";

  py::class_<RectPlacementEngine>(m, "RectPlacementEngine")
    .def(py::init<const std::string&>(), py::arg("json_path"))
    .def("load", &RectPlacementEngine::Load, py::arg("json_path"))
