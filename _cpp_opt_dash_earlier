import json
import time
from pathlib import Path

import numpy as np
import panel as pn
from bokeh.models import ColumnDataSource, Div, Slider
from bokeh.plotting import figure

import rect_place  # the compiled pybind11 module

pn.extension()

def _load_json(p: Path) -> dict:
    return json.loads(p.read_text())

def _rects_to_sources(xy: np.ndarray, wh: np.ndarray):
    # bokeh rect expects centers
    cx = xy[:, 0] + 0.5 * wh[:, 0]
    cy = xy[:, 1] + 0.5 * wh[:, 1]
    return dict(cx=cx, cy=cy, w=wh[:, 0], h=wh[:, 1])

def _bbox_from_xywh(xy: np.ndarray, wh: np.ndarray):
    minx = float(np.min(xy[:, 0]))
    miny = float(np.min(xy[:, 1]))
    maxx = float(np.max(xy[:, 0] + wh[:, 0]))
    maxy = float(np.max(xy[:, 1] + wh[:, 1]))
    return minx, miny, maxx, maxy

def _bbox_source(minx, miny, maxx, maxy):
    cx = 0.5 * (minx + maxx)
    cy = 0.5 * (miny + maxy)
    w = max(0.0, maxx - minx)
    h = max(0.0, maxy - miny)
    return dict(cx=[cx], cy=[cy], w=[w], h=[h])

def make_app(json_path: str):
    json_path = str(Path(json_path).resolve())
    cfg = _load_json(Path(json_path))

    # engine
    eng = rect_place.RectPlacementEngine(json_path)

    # initial plot data
    wh = eng.rect_wh()
    init_xy = np.zeros((eng.num_rectangles(), 2), dtype=np.float64)
    for i, k in enumerate(sorted(cfg["rectangles"].keys(), key=lambda s: int(s))):
        init_xy[i, 0] = cfg["rectangles"][k]["x"]
        init_xy[i, 1] = cfg["rectangles"][k]["y"]

    canvas_w = float(cfg["expected_params"]["canvas"]["width"])
    canvas_h = float(cfg["expected_params"]["canvas"]["height"])

    src_in = ColumnDataSource(_rects_to_sources(init_xy, wh))
    minx, miny, maxx, maxy = _bbox_from_xywh(init_xy, wh)
    src_in_bb = ColumnDataSource(_bbox_source(minx, miny, maxx, maxy))

    # output/iter plot sources (start = initial)
    src_it = ColumnDataSource(_rects_to_sources(init_xy, wh))
    src_it_bb = ColumnDataSource(_bbox_source(minx, miny, maxx, maxy))

    p = figure(title="Rectangles + Bounding Box (iteration view)",
               x_range=(0, canvas_w), y_range=(0, canvas_h),
               width=850, height=650, match_aspect=True)
    p.rect(x="cx", y="cy", width="w", height="h", source=src_it, fill_alpha=0.15, line_alpha=0.8)
    p.rect(x="cx", y="cy", width="w", height="h", source=src_it_bb, fill_alpha=0.0, line_alpha=1.0, line_width=3)

    p_in = figure(title="Input (initial)",
                  x_range=(0, canvas_w), y_range=(0, canvas_h),
                  width=850, height=650, match_aspect=True)
    p_in.rect(x="cx", y="cy", width="w", height="h", source=src_in, fill_alpha=0.15, line_alpha=0.8)
    p_in.rect(x="cx", y="cy", width="w", height="h", source=src_in_bb, fill_alpha=0.0, line_alpha=1.0, line_width=3)

    info = Div(text="<b>Status:</b> not optimized yet")

    def run_opt(_):
        t0 = time.time()
        eng.optimize()
        dt = time.time() - t0

        out_path = eng.default_output_path()
        eng.save_output_json(out_path)

        info.text = f"<b>Status:</b> optimized in {dt:.3f}s, saved output: {out_path}<br>" \
                    f"<b>Best iteration:</b> {eng.best_iteration_index()} / {eng.iteration_count()-1}"

        slider.end = max(0, eng.iteration_count() - 1)
        slider.value = eng.best_iteration_index()

        # jump to best immediately
        update_iter(slider.value)

    def update_iter(i: int):
        if eng.iteration_count() == 0:
            return

        xy = np.asarray(eng.iter_xy(int(i)))
        src_it.data = _rects_to_sources(xy, wh)

        minx, miny, maxx, maxy = _bbox_from_xywh(xy, wh)
        src_it_bb.data = _bbox_source(minx, miny, maxx, maxy)

        md = eng.iter_metrics(int(i))
        info.text = (
            f"<b>Status:</b> iter {i}<br>"
            f"aug_obj={md['augmented_objective']:.6g} | bbox_area={md['bbox_area']:.6g} | hpwl={md['hpwl']:.6g}<br>"
            f"overlap(raw area)={md['overlap']:.6g} | boundary={md['boundary_violation']:.6g} | aspect_vi={md['aspect_ratio_violation']:.6g}<br>"
            f"bbox_ar={md['bbox_aspect_ratio']:.6g} | bbox(cx,cy)=({md['bbox_cx']:.3f},{md['bbox_cy']:.3f})"
        )

    btn = pn.widgets.Button(name="Run optimization", button_type="primary")
    btn.on_click(run_opt)

    slider = Slider(title="Iteration", start=0, end=0, value=0, step=1)
    slider.on_change("value", lambda attr, old, new: update_iter(new))

    best_btn = pn.widgets.Button(name="Jump to best", button_type="success")
    best_btn.on_click(lambda _: update_iter(eng.best_iteration_index() if eng.iteration_count() else 0))

    layout = pn.Row(
        pn.Column(btn, best_btn, pn.pane.Bokeh(slider), pn.pane.Bokeh(p), info),
        pn.Column(pn.pane.Bokeh(p_in))
    )
    return layout

