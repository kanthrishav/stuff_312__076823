// ------------------------------
// Utility: timing
// ------------------------------
class Stopwatch
{
public:
  Stopwatch() : start_(std::chrono::high_resolution_clock::now()) {}
  double Seconds() const
  {
    const auto now = std::chrono::high_resolution_clock::now();
    return std::chrono::duration<double>(now - start_).count();
  }
private:
  std::chrono::high_resolution_clock::time_point start_;
};

// ------------------------------
// Domain classes (NO struct usage)
// ------------------------------
class Rectangle
{
public:
  Rectangle() : x_(0.0), y_(0.0), w_(0.0), h_(0.0) {}
  Rectangle(const double x, const double y, const double w, const double h)
    : x_(x), y_(y), w_(w), h_(h) {}

  double X() const { return x_; }
  double Y() const { return y_; }
  double W() const { return w_; }
  double H() const { return h_; }

  void SetXY(const double x, const double y) { x_ = x; y_ = y; }

  double Left() const { return x_; }
  double Right() const { return x_ + w_; }
  double Bottom() const { return y_; }
  double Top() const { return y_ + h_; }

  double Cx() const { return x_ + 0.5 * w_; }
  double Cy() const { return y_ + 0.5 * h_; }

  double Area() const { return w_ * h_; }

private:
  double x_, y_, w_, h_;
};

class Canvas
{
public:
  Canvas() : w_(0.0), h_(0.0) {}
  Canvas(const double w, const double h) : w_(w), h_(h) {}
  double W() const { return w_; }
  double H() const { return h_; }
  double Area() const { return w_ * h_; }
private:
  double w_, h_;
};

class BoundingBox
{
public:
  BoundingBox()
  : minx_(+std::numeric_limits<double>::infinity()),
    miny_(+std::numeric_limits<double>::infinity()),
    maxx_(-std::numeric_limits<double>::infinity()),
    maxy_(-std::numeric_limits<double>::infinity())
  {}

  void Reset()
  {
    minx_ = +std::numeric_limits<double>::infinity();
    miny_ = +std::numeric_limits<double>::infinity();
    maxx_ = -std::numeric_limits<double>::infinity();
    maxy_ = -std::numeric_limits<double>::infinity();
  }

  void ExpandByRect(const Rectangle& r)
  {
    minx_ = std::min(minx_, r.Left());
    miny_ = std::min(miny_, r.Bottom());
    maxx_ = std::max(maxx_, r.Right());
    maxy_ = std::max(maxy_, r.Top());
  }

  double MinX() const { return minx_; }
  double MinY() const { return miny_; }
  double MaxX() const { return maxx_; }
  double MaxY() const { return maxy_; }

  double Width() const { return std::max(0.0, maxx_ - minx_); }
  double Height() const { return std::max(0.0, maxy_ - miny_); }
  double Cx() const { return 0.5 * (minx_ + maxx_); }
  double Cy() const { return 0.5 * (miny_ + maxy_); }
  double Area() const { return Width() * Height(); }

  double AspectRatio() const
  {
    const double h = Height();
    if (h <= 1e-12) return std::numeric_limits<double>::infinity();
    return Width() / h;
  }

private:
  double minx_, miny_, maxx_, maxy_;
};

