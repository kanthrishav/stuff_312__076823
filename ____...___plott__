from __future__ import annotations

import argparse
import html
import json
import math
from pathlib import Path
from typing import Any, Dict, List, Sequence, Tuple

import plotly.graph_objects as go
from plotly.subplots import make_subplots


# ============================================================
# USER CONTROLS
# ============================================================
DEFAULT_STUDY_DIR = r"./studies"        # Can be overridden by --study_dir
JSON_GLOB = "*.json"
INCLUDE_PLOTLYJS = "cdn"                # True | False | "cdn"

GRID_COLUMNS = 4
GRID_ROWS = 3

PAGE_TITLE_SUFFIX = " - Multi-tab Study Dashboard"

PAGE_BACKGROUND_COLOR = "#061a40"      # dark blue
PAGE_TEXT_COLOR = "#d4a017"            # mustard yellow
CARD_BACKGROUND_COLOR = "#0b234f"
CARD_BORDER_COLOR = "#1f3d7a"
PLOT_BACKGROUND_COLOR = "#061a40"
PAPER_BACKGROUND_COLOR = "#061a40"
AXIS_GRID_COLOR = "#234a84"
TAB_ACTIVE_BACKGROUND = "#13336b"
TAB_INACTIVE_BACKGROUND = "#0b234f"
TAB_BORDER_COLOR = "#294f8b"

FONT_FAMILY = "Arial, Helvetica, sans-serif"
PAGE_TITLE_FONT_SIZE = 22
TAB_FONT_SIZE = 15
CARD_TITLE_FONT_SIZE = 15
CARD_BODY_FONT_SIZE = 13
PLOT_FONT_SIZE = 12

PLOT_CELL_HEIGHT = 300                 # per subplot row
PLOT_TOP_MARGIN = 85
PLOT_BOTTOM_MARGIN = 45
PLOT_LEFT_MARGIN = 55
PLOT_RIGHT_MARGIN = 35
SUBPLOT_HORIZONTAL_SPACING = 0.05
SUBPLOT_VERTICAL_SPACING = 0.10

SCATTER_SIZE = 6
LINE_WIDTH = 1.2
LINE_DASH = "dot"
LINE_COLOR = "#d4a017"
COLORSCALE = "Viridis"

TEXT_GRID_GAP_PX = 14
CARD_PADDING_PX = 12
CARD_BORDER_RADIUS_PX = 10
SECTION_MARGIN_TOP_PX = 18

SHOW_AXIS_TITLES = True
SHOW_LEGEND = False

ZERO_OVERLAP_TOL = 1e-12

# ============================================================
# CONSTANTS
# ============================================================
OUTPUT_META_KEYS = ["blocks", "nets", "pins", "maxVarPerBlock", "variants"]
OUTPUT_SERIES_KEYS = [
    "pureObj",
    "area",
    "aspect",
    "hpwl",
    "overlap",
    "boundary",
    "aspectViol",
    "augObj",
    "runtime",
]
HOVER_OUTPUT_KEYS = ["area", "hpwl", "overlap", "boundary", "aspectViol", "pureObj", "runtime"]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Build one multi-tab Plotly HTML dashboard per study JSON file."
    )
    parser.add_argument(
        "--study_dir",
        type=str,
        default=DEFAULT_STUDY_DIR,
        help="Directory containing study JSON files.",
    )
    return parser.parse_args()


def as_list(value: Any) -> List[Any]:
    return list(value) if isinstance(value, list) else []


def is_number(value: Any) -> bool:
    try:
        x = float(value)
        return math.isfinite(x)
    except (TypeError, ValueError):
        return False


def to_sort_float(value: Any, default: float = float("inf")) -> float:
    try:
        x = float(value)
        return x if math.isfinite(x) else default
    except (TypeError, ValueError):
        return default


def format_value(value: Any) -> str:
    if value is None:
        return "None"
    if isinstance(value, bool):
        return str(value)
    if isinstance(value, int):
        return str(value)
    if isinstance(value, float):
        if not math.isfinite(value):
            return str(value)
        return f"{value:.6g}"
    if is_number(value):
        value = float(value)
        return f"{value:.6g}"
    return str(value)


def html_escape(value: Any) -> str:
    return html.escape(format_value(value))


def load_json_file(json_path: Path) -> Dict[str, Any]:
    with json_path.open("r", encoding="utf-8") as f:
        return json.load(f)


def is_blank_usecase(usecase_data: Dict[str, Any]) -> bool:
    input_dict = usecase_data.get("input", {})
    output_dict = usecase_data.get("output", {})

    input_empty = all(len(as_list(v)) == 0 for v in input_dict.values()) if input_dict else True
    scalar_zero = all(to_sort_float(output_dict.get(k, 0), default=0.0) == 0.0 for k in OUTPUT_META_KEYS)
    output_lists_empty = all(len(as_list(output_dict.get(k, []))) == 0 for k in OUTPUT_SERIES_KEYS)

    return input_empty and scalar_zero and output_lists_empty


def first_input_keys(study_data: Dict[str, Any]) -> List[str]:
    for usecase_data in study_data.values():
        input_dict = usecase_data.get("input", {})
        if isinstance(input_dict, dict):
            return list(input_dict.keys())
    return []


def get_common_length(usecase_data: Dict[str, Any], param_name: str) -> int:
    input_dict = usecase_data.get("input", {})
    output_dict = usecase_data.get("output", {})

    series_to_align = [as_list(input_dict.get(param_name, []))]
    for key in HOVER_OUTPUT_KEYS + ["augObj"]:
        series_to_align.append(as_list(output_dict.get(key, [])))

    lengths = [len(s) for s in series_to_align]
    return min(lengths) if lengths else 0


def get_best_common_length(usecase_data: Dict[str, Any], input_keys: Sequence[str]) -> int:
    input_dict = usecase_data.get("input", {})
    output_dict = usecase_data.get("output", {})

    series_to_align: List[List[Any]] = [as_list(input_dict.get(k, [])) for k in input_keys]
    for key in ["augObj", "overlap", "boundary", "runtime"]:
        series_to_align.append(as_list(output_dict.get(key, [])))

    lengths = [len(s) for s in series_to_align]
    return min(lengths) if lengths else 0


def collect_runtime_range(study_data: Dict[str, Any]) -> Tuple[float, float]:
    runtime_values: List[float] = []
    for usecase_data in study_data.values():
        runtime_series = as_list(usecase_data.get("output", {}).get("runtime", []))
        runtime_values.extend([float(v) for v in runtime_series if is_number(v)])

    if not runtime_values:
        return 0.0, 1.0

    vmin = min(runtime_values)
    vmax = max(runtime_values)
    if math.isclose(vmin, vmax, rel_tol=0.0, abs_tol=1e-15):
        vmax = vmin + 1.0
    return vmin, vmax


def build_hover_template(param_name: str) -> str:
    return (
        f"{html.escape(param_name)}=%{{x}}<br>"
        f"augObj=%{{y}}<br>"
        f"area=%{{customdata[0]}}<br>"
        f"hpwl=%{{customdata[1]}}<br>"
        f"overlap=%{{customdata[2]}}<br>"
        f"boundary=%{{customdata[3]}}<br>"
        f"aspectViol=%{{customdata[4]}}<br>"
        f"pureObj=%{{customdata[5]}}<br>"
        f"runtime=%{{customdata[6]}}"
        f"<extra></extra>"
    )


def build_study_figure(
    study_name: str,
    study_data: Dict[str, Any],
    usecase_names: Sequence[str],
    param_name: str,
    runtime_range: Tuple[float, float],
) -> go.Figure:
    subplot_titles = [html.escape(name) for name in usecase_names]
    fig = make_subplots(
        rows=GRID_ROWS,
        cols=GRID_COLUMNS,
        subplot_titles=subplot_titles,
        horizontal_spacing=SUBPLOT_HORIZONTAL_SPACING,
        vertical_spacing=SUBPLOT_VERTICAL_SPACING,
    )

    runtime_min, runtime_max = runtime_range

    for idx, usecase_name in enumerate(usecase_names):
        row = (idx // GRID_COLUMNS) + 1
        col = (idx % GRID_COLUMNS) + 1

        usecase_data = study_data[usecase_name]
        if is_blank_usecase(usecase_data):
            fig.update_xaxes(visible=False, row=row, col=col)
            fig.update_yaxes(visible=False, row=row, col=col)
            continue

        n = get_common_length(usecase_data, param_name)
        if n <= 0:
            fig.update_xaxes(visible=False, row=row, col=col)
            fig.update_yaxes(visible=False, row=row, col=col)
            continue

        input_dict = usecase_data.get("input", {})
        output_dict = usecase_data.get("output", {})

        x_vals = as_list(input_dict.get(param_name, []))[:n]
        aug_vals = as_list(output_dict.get("augObj", []))[:n]
        runtime_vals = as_list(output_dict.get("runtime", []))[:n]

        customdata = list(
            zip(
                as_list(output_dict.get("area", []))[:n],
                as_list(output_dict.get("hpwl", []))[:n],
                as_list(output_dict.get("overlap", []))[:n],
                as_list(output_dict.get("boundary", []))[:n],
                as_list(output_dict.get("aspectViol", []))[:n],
                as_list(output_dict.get("pureObj", []))[:n],
                runtime_vals,
            )
        )

        fig.add_trace(
            go.Scatter(
                x=x_vals,
                y=aug_vals,
                mode="lines+markers",
                line=dict(color=LINE_COLOR, width=LINE_WIDTH, dash=LINE_DASH),
                marker=dict(
                    size=SCATTER_SIZE,
                    color=runtime_vals,
                    coloraxis="coloraxis",
                ),
                customdata=customdata,
                hovertemplate=build_hover_template(param_name),
                showlegend=SHOW_LEGEND,
            ),
            row=row,
            col=col,
        )

        fig.update_xaxes(
            showgrid=True,
            gridcolor=AXIS_GRID_COLOR,
            zeroline=False,
            row=row,
            col=col,
        )
        fig.update_yaxes(
            showgrid=True,
            gridcolor=AXIS_GRID_COLOR,
            zeroline=False,
            row=row,
            col=col,
        )

        if SHOW_AXIS_TITLES and row == GRID_ROWS:
            fig.update_xaxes(title_text=param_name, row=row, col=col)
        if SHOW_AXIS_TITLES and col == 1:
            fig.update_yaxes(title_text="augObj", row=row, col=col)

    fig.update_layout(
        title=dict(text=f"{html.escape(study_name)} — augObj vs {html.escape(param_name)}", x=0.5),
        height=(GRID_ROWS * PLOT_CELL_HEIGHT) + PLOT_TOP_MARGIN + PLOT_BOTTOM_MARGIN,
        margin=dict(
            l=PLOT_LEFT_MARGIN,
            r=PLOT_RIGHT_MARGIN,
            t=PLOT_TOP_MARGIN,
            b=PLOT_BOTTOM_MARGIN,
        ),
        paper_bgcolor=PAPER_BACKGROUND_COLOR,
        plot_bgcolor=PLOT_BACKGROUND_COLOR,
        font=dict(
            family=FONT_FAMILY,
            size=PLOT_FONT_SIZE,
            color=PAGE_TEXT_COLOR,
        ),
        coloraxis=dict(
            colorscale=COLORSCALE,
            cmin=runtime_min,
            cmax=runtime_max,
            colorbar=dict(
                title=dict(text="runtime", font=dict(color=PAGE_TEXT_COLOR)),
                tickfont=dict(color=PAGE_TEXT_COLOR),
            ),
        ),
    )

    for annotation in fig.layout.annotations:
        annotation.font = dict(
            family=FONT_FAMILY,
            size=CARD_TITLE_FONT_SIZE,
            color=PAGE_TEXT_COLOR,
        )

    return fig


def build_meta_grid_html(study_data: Dict[str, Any], usecase_names: Sequence[str]) -> str:
    cards: List[str] = []
    for usecase_name in usecase_names:
        usecase_data = study_data[usecase_name]
        body_lines: List[str] = []

        if not is_blank_usecase(usecase_data):
            output_dict = usecase_data.get("output", {})
            for key in OUTPUT_META_KEYS:
                body_lines.append(
                    f'<div><span class="label">{html.escape(key)}:</span> '
                    f'<span class="value">{html_escape(output_dict.get(key, ""))}</span></div>'
                )

        cards.append(
            f"""
            <div class="grid-card">
                <div class="grid-card-title">{html.escape(usecase_name)}</div>
                <div class="grid-card-body">
                    {''.join(body_lines)}
                </div>
            </div>
            """
        )

    return f"""
    <div class="section-title">Usecase summary</div>
    <div class="info-grid">
        {''.join(cards)}
    </div>
    """


def choose_best_index(usecase_data: Dict[str, Any], input_keys: Sequence[str]) -> Tuple[int | None, str]:
    n = get_best_common_length(usecase_data, input_keys)
    if n <= 0:
        return None, ""

    output_dict = usecase_data.get("output", {})
    overlap = as_list(output_dict.get("overlap", []))[:n]
    aug_obj = as_list(output_dict.get("augObj", []))[:n]
    boundary = as_list(output_dict.get("boundary", []))[:n]

    zero_overlap_indices = [
        i for i, v in enumerate(overlap) if abs(to_sort_float(v, default=float("inf"))) <= ZERO_OVERLAP_TOL
    ]

    if zero_overlap_indices:
        best_idx = min(
            zero_overlap_indices,
            key=lambda i: (
                to_sort_float(aug_obj[i]),
                to_sort_float(boundary[i]),
                i,
            ),
        )
        return best_idx, "overlap = 0 satisfied"

    best_idx = min(
        range(n),
        key=lambda i: (
            to_sort_float(overlap[i]),
            to_sort_float(aug_obj[i]),
            to_sort_float(boundary[i]),
            i,
        ),
    )
    return best_idx, "fallback used: no overlap = 0 point"


def build_best_grid_html(
    study_data: Dict[str, Any],
    usecase_names: Sequence[str],
    input_keys: Sequence[str],
) -> str:
    cards: List[str] = []

    for usecase_name in usecase_names:
        usecase_data = study_data[usecase_name]

        if is_blank_usecase(usecase_data):
            cards.append(
                f"""
                <div class="grid-card">
                    <div class="grid-card-title">{html.escape(usecase_name)}</div>
                    <div class="grid-card-body"></div>
                </div>
                """
            )
            continue

        best_idx, reason = choose_best_index(usecase_data, input_keys)
        if best_idx is None:
            cards.append(
                f"""
                <div class="grid-card">
                    <div class="grid-card-title">{html.escape(usecase_name)}</div>
                    <div class="grid-card-body"></div>
                </div>
                """
            )
            continue

        input_dict = usecase_data.get("input", {})
        output_dict = usecase_data.get("output", {})

        input_lines = []
        for key in input_keys:
            series = as_list(input_dict.get(key, []))
            value = series[best_idx] if best_idx < len(series) else ""
            input_lines.append(
                f'<div><span class="label">{html.escape(key)}:</span> '
                f'<span class="value">{html_escape(value)}</span></div>'
            )

        metric_lines = []
        for key in ["augObj", "overlap", "boundary", "runtime", "area", "hpwl", "pureObj"]:
            series = as_list(output_dict.get(key, []))
            value = series[best_idx] if best_idx < len(series) else ""
            metric_lines.append(
                f'<div><span class="label">{html.escape(key)}:</span> '
                f'<span class="value">{html_escape(value)}</span></div>'
            )

        cards.append(
            f"""
            <div class="grid-card">
                <div class="grid-card-title">{html.escape(usecase_name)}</div>
                <div class="grid-card-body">
                    <div><span class="label">selection:</span> <span class="value">{html.escape(reason)}</span></div>
                    <div><span class="label">index:</span> <span class="value">{best_idx}</span></div>
                    <div class="subsection-title">inputs</div>
                    {''.join(input_lines)}
                    <div class="subsection-title">selected outputs</div>
                    {''.join(metric_lines)}
                </div>
            </div>
            """
        )

    return f"""
    <div class="section-title">Best input set per usecase</div>
    <div class="info-grid">
        {''.join(cards)}
    </div>
    """


def build_page_css() -> str:
    return f"""
    <style>
        * {{
            box-sizing: border-box;
        }}
        body {{
            margin: 0;
            background: {PAGE_BACKGROUND_COLOR};
            color: {PAGE_TEXT_COLOR};
            font-family: {FONT_FAMILY};
        }}
        .page {{
            width: 100%;
            padding: 18px 18px 28px 18px;
        }}
        .page-title {{
            font-size: {PAGE_TITLE_FONT_SIZE}px;
            font-weight: 700;
            margin-bottom: 14px;
        }}
        .tabs {{
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 14px;
        }}
        .tab-button {{
            background: {TAB_INACTIVE_BACKGROUND};
            color: {PAGE_TEXT_COLOR};
            border: 1px solid {TAB_BORDER_COLOR};
            border-radius: 8px;
            padding: 10px 14px;
            cursor: pointer;
            font-size: {TAB_FONT_SIZE}px;
            font-family: {FONT_FAMILY};
        }}
        .tab-button.active {{
            background: {TAB_ACTIVE_BACKGROUND};
            font-weight: 700;
        }}
        .tab-content {{
            display: none;
            width: 100%;
        }}
        .tab-content.active {{
            display: block;
        }}
        .plot-block {{
            width: 100%;
            overflow-x: hidden;
            overflow-y: visible;
        }}
        .section-title {{
            margin-top: {SECTION_MARGIN_TOP_PX}px;
            margin-bottom: 10px;
            font-size: {CARD_TITLE_FONT_SIZE + 1}px;
            font-weight: 700;
        }}
        .info-grid {{
            display: grid;
            grid-template-columns: repeat({GRID_COLUMNS}, minmax(0, 1fr));
            gap: {TEXT_GRID_GAP_PX}px;
            width: 100%;
        }}
        .grid-card {{
            background: {CARD_BACKGROUND_COLOR};
            border: 1px solid {CARD_BORDER_COLOR};
            border-radius: {CARD_BORDER_RADIUS_PX}px;
            padding: {CARD_PADDING_PX}px;
            min-height: 150px;
            overflow: hidden;
        }}
        .grid-card-title {{
            font-size: {CARD_TITLE_FONT_SIZE}px;
            font-weight: 700;
            margin-bottom: 8px;
            word-break: break-word;
        }}
        .grid-card-body {{
            font-size: {CARD_BODY_FONT_SIZE}px;
            line-height: 1.45;
            word-break: break-word;
        }}
        .subsection-title {{
            margin-top: 8px;
            margin-bottom: 4px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }}
        .label {{
            font-weight: 700;
        }}
        .value {{
            font-weight: 400;
        }}
        @media (max-width: 1300px) {{
            .info-grid {{
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }}
        }}
        @media (max-width: 980px) {{
            .info-grid {{
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }}
        }}
        @media (max-width: 620px) {{
            .info-grid {{
                grid-template-columns: 1fr;
            }}
        }}
    </style>
    """


def build_tab_script() -> str:
    return """
    <script>
        function openTab(tabIndex) {
            const buttons = document.querySelectorAll('.tab-button');
            const contents = document.querySelectorAll('.tab-content');

            buttons.forEach((btn, i) => {
                btn.classList.toggle('active', i === tabIndex);
            });

            contents.forEach((content, i) => {
                content.classList.toggle('active', i === tabIndex);
            });

            window.dispatchEvent(new Event('resize'));
        }

        document.addEventListener('DOMContentLoaded', function () {
            openTab(0);
        });
    </script>
    """


def build_study_html(
    study_name: str,
    tab_payloads: Sequence[Tuple[str, str]],
    meta_grid_html: str,
    best_grid_html: str,
) -> str:
    tab_buttons = []
    tab_contents = []

    for idx, (tab_name, fig_html) in enumerate(tab_payloads):
        tab_buttons.append(
            f'<button class="tab-button" onclick="openTab({idx})">{html.escape(tab_name)}</button>'
        )
        tab_contents.append(
            f"""
            <div class="tab-content">
                <div class="plot-block">{fig_html}</div>
                {meta_grid_html}
                {best_grid_html}
            </div>
            """
        )

    return f"""
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <title>{html.escape(study_name)}{html.escape(PAGE_TITLE_SUFFIX)}</title>
        {build_page_css()}
    </head>
    <body>
        <div class="page">
            <div class="page-title">{html.escape(study_name)}{html.escape(PAGE_TITLE_SUFFIX)}</div>
            <div class="tabs">
                {''.join(tab_buttons)}
            </div>
            {''.join(tab_contents)}
        </div>
        {build_tab_script()}
    </body>
    </html>
    """


def process_study_file(json_path: Path) -> Path:
    study_data = load_json_file(json_path)
    if not isinstance(study_data, dict):
        raise ValueError(f"{json_path.name} does not contain a top-level JSON object.")

    usecase_names = list(study_data.keys())
    input_keys = first_input_keys(study_data)
    runtime_range = collect_runtime_range(study_data)

    meta_grid_html = build_meta_grid_html(study_data, usecase_names)
    best_grid_html = build_best_grid_html(study_data, usecase_names, input_keys)

    tab_payloads: List[Tuple[str, str]] = []
    for tab_idx, param_name in enumerate(input_keys):
        fig = build_study_figure(
            study_name=json_path.stem,
            study_data=study_data,
            usecase_names=usecase_names,
            param_name=param_name,
            runtime_range=runtime_range,
        )
        fig_html = fig.to_html(
            full_html=False,
            include_plotlyjs=INCLUDE_PLOTLYJS if tab_idx == 0 else False,
            config={"responsive": True},
        )
        tab_payloads.append((param_name, fig_html))

    if not tab_payloads:
        empty_html = """
        <div class="section-title">No input keys found</div>
        """
        tab_payloads.append(("No tabs", empty_html))

    final_html = build_study_html(
        study_name=json_path.stem,
        tab_payloads=tab_payloads,
        meta_grid_html=meta_grid_html,
        best_grid_html=best_grid_html,
    )

    output_html_path = json_path.with_suffix(".html")
    output_html_path.write_text(final_html, encoding="utf-8")
    return output_html_path


def main() -> None:
    args = parse_args()
    study_dir = Path(args.study_dir).expanduser().resolve()

    if not study_dir.exists():
        raise FileNotFoundError(f"Study directory not found: {study_dir}")
    if not study_dir.is_dir():
        raise NotADirectoryError(f"Path is not a directory: {study_dir}")

    json_files = sorted(study_dir.glob(JSON_GLOB))
    if not json_files:
        raise FileNotFoundError(f"No JSON files found in: {study_dir}")

    generated_files: List[Path] = []
    for json_file in json_files:
        generated_files.append(process_study_file(json_file))

    print("Generated HTML files:")
    for path in generated_files:
        print(f"  {path}")


if __name__ == "__main__":
    main()
