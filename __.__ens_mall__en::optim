1) include/opt_ga_pagmo.hpp
#pragma once
#include <pagmo/algorithms/sga.hpp>
#include <pagmo/population.hpp>
#include <pagmo/problem.hpp>
#include <random>
#include <vector>
#include <stdexcept>
#include <algorithm>
#include <armadillo>

// Wrap your LayoutObjective (Evaluate(arma::mat)) into a pagmo problem
struct PagmoLayoutProblem {
  std::size_t dim;
  class LayoutObjective *obj;
  std::vector<double> lb, ub;

  std::vector<double> fitness(const std::vector<double> &dv) const {
    // zero-copy view over dv
    arma::mat x_view(const_cast<double*>(dv.data()), dim, 1, /*copy_aux_mem*/ false, /*strict*/ true);
    const double f = obj->Evaluate(x_view);
    return { f }; // minimization
  }

  std::pair<std::vector<double>, std::vector<double>> get_bounds() const {
    return {lb, ub};
  }
};

inline pagmo::sga::selection parse_sga_selection(const std::string &s) {
  if (s == "tournament") return pagmo::sga::selection::TOURNAMENT;
  if (s == "truncated")  return pagmo::sga::selection::TRUNCATED;
  throw std::runtime_error("GA.selection must be 'tournament' or 'truncated' (got '" + s + "')");
}

// Drive GA one generation at a time, calling your callback every gen.
template <typename CallbackT>
inline void OptimizeGA_Pagmo(
    LayoutObjective &obj,
    arma::mat &x,                          // 2N x 1 (kept for API compatibility)
    CallbackT &cb,
    const std::size_t popsize,
    const std::size_t maxgen,
    const double cr,
    const double m,
    const double param_m,
    const unsigned param_s,
    const std::string &selection_str,
    const std::uint64_t seed,
    const std::vector<double> &lb,
    const std::vector<double> &ub)
{
  const std::size_t dim = static_cast<std::size_t>(x.n_rows);

  PagmoLayoutProblem prob{dim, &obj, lb, ub};
  pagmo::problem p{prob};

  pagmo::population pop(p, popsize, static_cast<unsigned>(seed));

  // We evolve 1 generation per loop to guarantee one callback per generation.
  pagmo::sga alg(
      1u,
      cr,
      m,
      param_m,
      param_s,
      parse_sga_selection(selection_str),
      static_cast<unsigned>(seed)
  );

  for (std::size_t gen = 0; gen < maxgen; ++gen) {
    pop = alg.evolve(pop);

    // champion_x() is the best solution in the population
    const auto &champ = pop.champion_x();
    arma::mat champ_view(const_cast<double*>(champ.data()), dim, 1, false, true);

    // call your callback (stores metrics+coords; supports early stop via target objective)
    if (cb.StepTaken(alg, obj, champ_view)) {
      // copy champion into x (optional; keeps the "x is final best" convention)
      x = champ_view;
      return;
    }
  }

  // final: set x to champion
  const auto &champ = pop.champion_x();
  arma::mat champ_view(const_cast<double*>(champ.data()), dim, 1, false, true);
  x = champ_view;
}


pagmo::sga parameters are taken from its documented constructor.

2) include/opt_adam_torch.hpp

This uses libtorch Adam but computes gradients with SPSA (because you don’t have analytic gradients).

#pragma once
#include <torch/torch.h>
#include <armadillo>
#include <random>
#include <vector>
#include <cmath>
#include <algorithm>
#include <cstdint>

inline double clampd(double v, double lo, double hi) { return std::min(hi, std::max(lo, v)); }

template <typename CallbackT>
inline void OptimizeADAM_Torch_SPSA(
    LayoutObjective &obj,
    arma::mat &x,                // 2N x 1, updated in-place
    CallbackT &cb,
    const std::size_t maxiter,
    const double lr,
    const double beta1,
    const double beta2,
    const double eps,
    const double weight_decay,
    const bool amsgrad,
    const std::size_t spsa_samples,
    const double ck0,
    const double ck_decay,
    const double clip_grad_norm,
    const bool project_to_canvas,
    const double canvas_w,
    const double canvas_h,
    const std::uint64_t seed)
{
  const std::size_t dim = static_cast<std::size_t>(x.n_rows);

  // Tensor view over Armadillo memory (no copy). Note: x must stay alive.
  torch::Tensor params = torch::from_blob(
      x.memptr(),
      {(long long)dim},
      torch::TensorOptions().dtype(torch::kFloat64).device(torch::kCPU)
  );
  params.set_requires_grad(true);

  torch::optim::AdamOptions opts(lr);
  opts.betas(std::make_tuple(beta1, beta2));
  opts.eps(eps);
  opts.weight_decay(weight_decay);
  opts.amsgrad(amsgrad);

  torch::optim::Adam optim({params}, opts);

  std::mt19937_64 rng(seed);
  std::uniform_int_distribution<int> pm01(0, 1);

  std::vector<double> grad(dim, 0.0);
  std::vector<int> delta(dim, 1);

  for (std::size_t iter = 0; iter < maxiter; ++iter) {
    std::fill(grad.begin(), grad.end(), 0.0);

    // ck schedule
    const double ck = ck0 / std::pow(double(iter + 1), ck_decay);

    // SPSA gradient estimate (averaged)
    for (std::size_t s = 0; s < spsa_samples; ++s) {
      for (std::size_t i = 0; i < dim; ++i) delta[i] = pm01(rng) ? 1 : -1;

      // x_plus
      for (std::size_t i = 0; i < dim; ++i) x(i, 0) += ck * double(delta[i]);
      if (project_to_canvas) {
        for (std::size_t k = 0; k < dim/2; ++k) {
          x(2*k + 0, 0) = clampd(x(2*k + 0, 0), 0.0, canvas_w);
          x(2*k + 1, 0) = clampd(x(2*k + 1, 0), 0.0, canvas_h);
        }
      }
      const double f_plus = obj.Evaluate(x);

      // x_minus
      for (std::size_t i = 0; i < dim; ++i) x(i, 0) -= 2.0 * ck * double(delta[i]);
      if (project_to_canvas) {
        for (std::size_t k = 0; k < dim/2; ++k) {
          x(2*k + 0, 0) = clampd(x(2*k + 0, 0), 0.0, canvas_w);
          x(2*k + 1, 0) = clampd(x(2*k + 1, 0), 0.0, canvas_h);
        }
      }
      const double f_minus = obj.Evaluate(x);

      // restore original x
      for (std::size_t i = 0; i < dim; ++i) x(i, 0) += ck * double(delta[i]);

      const double scale = (f_plus - f_minus) / (2.0 * ck);
      for (std::size_t i = 0; i < dim; ++i) {
        grad[i] += scale * (1.0 / double(delta[i]));
      }
    }

    for (auto &g : grad) g /= double(std::max<std::size_t>(1, spsa_samples));

    // optional grad clipping
    if (clip_grad_norm > 0.0) {
      double nrm2 = 0.0;
      for (double g : grad) nrm2 += g*g;
      const double nrm = std::sqrt(nrm2);
      if (nrm > clip_grad_norm) {
        const double k = clip_grad_norm / (nrm + 1e-12);
        for (auto &g : grad) g *= k;
      }
    }

    // set gradient tensor (copy grad -> tensor, small relative to objective eval)
    torch::Tensor g = torch::empty_like(params);
    std::memcpy(g.data_ptr<double>(), grad.data(), dim * sizeof(double));

    optim.zero_grad();
    if (!params.grad().defined()) {
      params.mutable_grad() = g;
    } else {
      params.grad().copy_(g);
    }

    optim.step(); // updates params -> updates x memory (shared)

    if (project_to_canvas) {
      for (std::size_t k = 0; k < dim/2; ++k) {
        x(2*k + 0, 0) = clampd(x(2*k + 0, 0), 0.0, canvas_w);
        x(2*k + 1, 0) = clampd(x(2*k + 1, 0), 0.0, canvas_h);
      }
    }

    // Your callback stores history + checks target objective stop
    if (cb.StepTaken(optim, obj, x)) return;
  }
}


This keeps your interface intact and uses Adam from libtorch. The SPSA gradient estimator is what makes Adam workable for your “Evaluate-only” objective.

PyTorch provides libtorch + CMake integration docs.

