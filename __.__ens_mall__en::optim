  // --- ADAM (SPSA-gradient) manual loop ---
  auto run_adam_spsa = [&](const AdamParams& p) {
    struct DummyOpt {} dummy;

    const arma::uword dim = x.n_elem;
    arma::mat m(dim, 1, arma::fill::zeros);
    arma::mat v(dim, 1, arma::fill::zeros);
    arma::mat g(dim, 1, arma::fill::zeros);

    // Record initial point as iteration 0 (so plotting always has something).
    {
      arma::mat x0 = x; // stable lvalue for callback
      if (cb.StepTaken(dummy, obj, x0)) { x = x0; return; }
    }

    for (std::size_t t = 1; t <= p.maxIterations; ++t) {
      // SPSA-style gradient estimate: 2 evals per iteration
      const double ck = p.grad_perturb / std::pow(double(t), p.grad_gamma);

      arma::mat delta(dim, 1);
      delta.randu();
      delta.transform([](double u) { return (u < 0.5) ? -1.0 : 1.0; });

      arma::mat xp = x + ck * delta;
      arma::mat xm = x - ck * delta;

      const double fp = obj.Evaluate(xp);
      const double fm = obj.Evaluate(xm);

      const double scale = (fp - fm) / (2.0 * ck);

      // g(i) = scale / delta(i)  (delta(i) is ±1)
      for (arma::uword i = 0; i < dim; ++i) g(i, 0) = scale / delta(i, 0);

      if (p.grad_noise > 0.0) {
        arma::mat n(dim, 1);
        n.randn();
        g += p.grad_noise * n;
      }

      // Adam update
      m = p.beta1 * m + (1.0 - p.beta1) * g;
      v = p.beta2 * v + (1.0 - p.beta2) * arma::square(g);

      const double b1t = 1.0 - std::pow(p.beta1, double(t));
      const double b2t = 1.0 - std::pow(p.beta2, double(t));
      arma::mat mhat = m / b1t;
      arma::mat vhat = v / b2t;

      x -= p.stepSize * (mhat / (arma::sqrt(vhat) + p.eps));

      // IMPORTANT: callback each iteration with a stable arma::mat lvalue
      arma::mat xt = x;
      const bool stop = cb.StepTaken(dummy, obj, xt);
      x = xt;
      if (stop) break;

      // Optional tolerance stop (rarely used; keep it cheap)
      if (p.tolerance > 0.0) {
        // if change is tiny, stop
        if (arma::norm(p.stepSize * (mhat / (arma::sqrt(vhat) + p.eps))) < p.tolerance) break;
      }
    }
  };


This is fast (2 objective evals/iter, no O(dim) finite-diff loop) and guarantees your IterationCallback is called each iteration.

