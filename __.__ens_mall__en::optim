B) Callback upgrade: support both StepTaken and GenerationalStepTaken

This makes your metrics/history collection work correctly for population-based optimizers too.

File: wherever IterationCallback is defined (your snippet shows it near Placement).

REPLACE your current IterationCallback with:

class IterationCallback {
public:
  IterationCallback()
    : eval_(nullptr), store_(nullptr),
      stopping_mode_("maxiter"), stop_value_(0.0), iter_(0) {}

  void init(const LayoutEvaluator* eval,
            HistoryStore* store,
            const std::string& stopping_mode,
            const double stop_value)
  {
    eval_ = eval;
    store_ = store;
    stopping_mode_ = stopping_mode;
    stop_value_ = stop_value;
    iter_ = 0;
  }

  // Called by many optimizers (single candidate).
  template<typename OptimizerType, typename FunctionType, typename MatType>
  bool StepTaken(OptimizerType&, FunctionType&, MatType& coordinates)
  {
    const double* xy = coordinates.memptr();
    Metrics m = eval_->compute_all(xy, iter_);
    store_->push(coordinates, m);
    ++iter_;
    if (stopping_mode_ == "target_objective") return (m.augmented_objective <= stop_value_);
    return false;
  }

  // Called by population/generational optimizers.
  template<typename OptimizerType,
           typename... FunctionTypes,
           typename MatType,
           typename ObjectivesVecType,
           typename IndicesType>
  bool GenerationalStepTaken(OptimizerType&,
                             std::tuple<FunctionTypes...>&,
                             MatType& coordinates,
                             ObjectivesVecType& objectives,
                             IndicesType&)
  {
    // We assume single-objective: objectives[0] is a column vector (one value per population member).
    // Find best member index.
    std::size_t bestIdx = 0;
    double bestObj = objectives;

    const auto& obj0 = objectives[0];
    for (std::size_t i = 1; i < (std::size_t) obj0.n_elem; ++i) {
      if (obj0(i) < bestObj) { bestObj = obj0(i); bestIdx = i; }
    }

    // coordinates is typically [dim x popSize]. Best vector is column bestIdx.
    auto bestCol = coordinates.col(bestIdx); // Armadillo subview (no copy)
    const double* xy = bestCol.memptr();

    Metrics m = eval_->compute_all(xy, iter_);
    store_->push(bestCol, m);
    ++iter_;

    if (stopping_mode_ == "target_objective") return (m.augmented_objective <= stop_value_);
    return false;
  }

private:
  const LayoutEvaluator* eval_;
  HistoryStore* store_;
  std::string stopping_mode_;
  double stop_value_;
  std::size_t iter_;
};

C) ADAM wrapper: make your objective look like a separable differentiable function (NumFunctions=1) + SPSA-gradient

This is the key that makes Adam usable without writing an analytic gradient.

INSERT this helper class near LayoutObjective (same .cpp file as Placement::execute() is fine):

class LayoutSeparableSPSA {
public:
  explicit LayoutSeparableSPSA(LayoutEvaluator* eval,
                               const double evalStep)
    : eval_(eval), c_(evalStep) {}

  // Separable interface.
  std::size_t NumFunctions() const { return 1; }

  double Evaluate(const arma::mat& x) const {
    return eval_->evaluate_objective(x);
  }

  double Evaluate(const std::size_t /*i*/, const arma::mat& x) const {
    return eval_->evaluate_objective(x);
  }

  // SPSA gradient estimate: O(1) objective calls (2 calls), independent of dimension.
  void Gradient(const std::size_t /*i*/, const arma::mat& x, arma::mat& g) const {
    // Δ in {+1,-1}
    arma::mat delta = arma::randi<arma::mat>(x.n_rows, x.n_cols, arma::distr_param(0, 1));
    delta.transform([](arma::uword v) { return (v == 0) ? -1.0 : +1.0; });

    arma::mat x_plus  = x + c_ * delta;
    arma::mat x_minus = x - c_ * delta;

    const double f_plus  = eval_->evaluate_objective(x_plus);
    const double f_minus = eval_->evaluate_objective(x_minus);

    const double scale = (f_plus - f_minus) / (2.0 * c_);
    g.set_size(x.n_rows, x.n_cols);
    g = scale / delta; // componentwise (since delta is ±1)
  }

private:
  LayoutEvaluator* eval_;
  double c_;
};


This is the fastest practical way to support Adam on your non-smooth objective.

D) GA (custom real-coded GA) — minimal but complete

INSERT this helper class near Placement (same .cpp):

class RealCodedGA {
public:
  struct Params {
    std::size_t populationSize;
    std::size_t maxGenerations;

    double eliteFraction;
    std::size_t tournamentSize;

    double crossoverRate;
    double blendAlpha;

    double mutationRate;
    double mutationSigma;

    std::vector<double> lowerBound;
    std::vector<double> upperBound;

    double tolerance;
    std::size_t stallGenerations;
  };

  RealCodedGA(LayoutEvaluator* eval, HistoryStore* store, IterationCallback* cb,
              const Params& p, const std::string& stopMode, double stopValue)
    : eval_(eval), store_(store), cb_(cb), p_(p), stopMode_(stopMode), stopValue_(stopValue) {}

  void Optimize(arma::mat& x0)
  {
    const std::size_t dim = (std::size_t) x0.n_rows;

    // bounds (if empty -> no clamp)
    const bool hasBounds = (p_.lowerBound.size() == dim && p_.upperBound.size() == dim);

    arma::mat pop(dim, p_.populationSize);
    arma::vec fit(p_.populationSize);

    // init population around x0 (Gaussian)
    pop.each_col() = x0;
    pop += p_.mutationSigma * arma::randn<arma::mat>(dim, p_.populationSize);

    if (hasBounds) clamp(pop);

    evalPop(pop, fit);

    double best = fit.min();
    std::size_t stall = 0;

    for (std::size_t gen = 0; gen < p_.maxGenerations; ++gen)
    {
      // record best-of-generation into HistoryStore via callback semantics
      const arma::uword bestIdx = fit.index_min();
      arma::mat bestCol = pop.col(bestIdx);
      // emulate callback "StepTaken" so your history stays consistent
      // (this will compute full Metrics and push)
      if (cb_->StepTaken(*this, *this, bestCol)) { x0 = bestCol; return; }

      if (stopMode_ == "target_objective") {
        const double obj = eval_->evaluate_objective(bestCol);
        if (obj <= stopValue_) { x0 = bestCol; return; }
      }

      // stall detection
      if (fit(bestIdx) + p_.tolerance < best) { best = fit(bestIdx); stall = 0; }
      else { ++stall; if (stall >= p_.stallGenerations) { x0 = bestCol; return; } }

      // create next population
      arma::mat nextPop(dim, p_.populationSize);

      // elitism
      const std::size_t eliteCount = std::max<std::size_t>(1, (std::size_t) std::floor(p_.eliteFraction * p_.populationSize));
      arma::uvec sortedIdx = arma::sort_index(fit);
      for (std::size_t e = 0; e < eliteCount; ++e) nextPop.col(e) = pop.col(sortedIdx(e));

      // fill rest
      for (std::size_t k = eliteCount; k < p_.populationSize; ++k) {
        const arma::uword p1 = tournamentSelect(fit);
        const arma::uword p2 = tournamentSelect(fit);

        arma::vec child = pop.col(p1);

        if (arma::randu() < p_.crossoverRate) {
          child = blendCrossover(pop.col(p1), pop.col(p2));
        }
        if (arma::randu() < p_.mutationRate) {
          child += p_.mutationSigma * arma::randn<arma::vec>(dim);
        }

        nextPop.col(k) = child;
      }

      pop = std::move(nextPop);
      if (hasBounds) clamp(pop);
      evalPop(pop, fit);
    }

    // final best
    x0 = pop.col(fit.index_min());
  }

private:
  void evalPop(const arma::mat& pop, arma::vec& fit)
  {
    for (arma::uword i = 0; i < pop.n_cols; ++i) {
      fit(i) = eval_->evaluate_objective(pop.col(i));
    }
  }

  arma::uword tournamentSelect(const arma::vec& fit)
  {
    arma::uword best = (arma::uword) (arma::randu() * fit.n_elem);
    for (std::size_t t = 1; t < p_.tournamentSize; ++t) {
      arma::uword j = (arma::uword) (arma::randu() * fit.n_elem);
      if (fit(j) < fit(best)) best = j;
    }
    return best;
  }

  arma::vec blendCrossover(const arma::vec& a, const arma::vec& b)
  {
    // BLX-α
    arma::vec lo = arma::min(a, b);
    arma::vec hi = arma::max(a, b);
    arma::vec d  = hi - lo;
    arma::vec minv = lo - p_.blendAlpha * d;
    arma::vec maxv = hi + p_.blendAlpha * d;
    return minv + arma::randu<arma::vec>(a.n_elem) % (maxv - minv);
  }

  void clamp(arma::mat& pop)
  {
    for (arma::uword r = 0; r < pop.n_rows; ++r) {
      const double lo = p_.lowerBound[(std::size_t) r];
      const double hi = p_.upperBound[(std::size_t) r];
      pop.row(r).transform([&](double v){ return std::min(hi, std::max(lo, v)); });
    }
  }

private:
  LayoutEvaluator* eval_;
  HistoryStore* store_;
  IterationCallback* cb_;
  Params p_;
  std::string stopMode_;
  double stopValue_;
};

3) Placement::execute() — implement selection for all optimizers

File: src/placement.cpp (or where Placement::execute() is implemented)
REPLACE the body of your execute() with this:

#include <ensmallen.hpp>

// ... keep your other includes

void execute()
{
  arma::arma_rng::set_seed(static_cast<arma::uword>(cfg_.optimizer.common.seed));

  LayoutObjective obj(&evaluator_);
  arma::mat x = evaluator_.initial_point();

  IterationCallback cb;
  cb.init(&evaluator_, &store_,
          cfg_.optimizer.common.stopping_criteria,
          cfg_.optimizer.common.stopping_criteria_value);

  Stopwatch sw;

  // tolerance passed to some optimizers is only meaningful for target objective mode
  const double targetTol =
    (cfg_.optimizer.common.stopping_criteria == "target_objective")
      ? cfg_.optimizer.common.stopping_criteria_value
      : -1.0;

  switch (cfg_.optimizer.id)
  {
    case OptimizerId::DE:
    {
      const auto& p = cfg_.optimizer.de;
      ens::DE optimizer(p.popSize, p.maxIterations, p.crossoverRate, p.differentialWeight, targetTol);
      optimizer.Optimize(obj, x, cb);
      break;
    }

    case OptimizerId::SA:
    {
      const auto& p = cfg_.optimizer.sa;
      // ExponentialSchedule(lambda) per docs :contentReference[oaicite:7]{index=7}
      ens::ExponentialSchedule schedule(p.cooling_lambda);
      ens::SA<ens::ExponentialSchedule> optimizer(
        schedule,
        p.maxIterations,
        p.initT,
        p.initMoves,
        p.moveCtrlSweep,
        p.tolerance,
        p.maxToleranceSweep,
        p.maxMoveCoef,
        p.initMoveCoef,
        p.gain
      );
      optimizer.Optimize(obj, x, cb);
      break;
    }

    case OptimizerId::CNE:
    {
      const auto& p = cfg_.optimizer.cne;
      ens::CNE optimizer(p.populationSize, p.maxGenerations, p.mutationProb, p.selectPercent, p.tolerance);
      optimizer.Optimize(obj, x, cb);
      break;
    }

    case OptimizerId::PSO:
    {
      auto p = cfg_.optimizer.pso;
      const std::size_t dim = (std::size_t) x.n_rows;

      // If bounds omitted, derive from canvas (centers allowed anywhere in [0,W]/[0,H]).
      if (p.lowerBound.size() != dim || p.upperBound.size() != dim) {
        p.lowerBound.assign(dim, 0.0);
        p.upperBound.assign(dim, 0.0);
        const double W = cfg_.expected.canvas.W();
        const double H = cfg_.expected.canvas.H();
        for (std::size_t i = 0; i < dim; i += 2) {
          p.lowerBound[i]   = 0.0;
          p.upperBound[i]   = W;
          p.lowerBound[i+1] = 0.0;
          p.upperBound[i+1] = H;
        }
      }

      arma::vec lb(p.lowerBound);
      arma::vec ub(p.upperBound);

      ens::PSO optimizer(p.numParticles, p.maxIterations, lb, ub,
                         p.inertiaWeight, p.cognitiveCoeff, p.socialCoeff, p.tolerance);
      optimizer.Optimize(obj, x, cb);
      break;
    }

    case OptimizerId::SPSA:
    {
      const auto& p = cfg_.optimizer.spsa;
      ens::SPSA optimizer(p.alpha, p.gamma, p.stepSize, p.evaluationStepSize, p.maxIterations, p.tolerance);
      optimizer.Optimize(obj, x, cb);
      break;
    }

    case OptimizerId::ADAM:
    {
      // Adam requires differentiable separable interface. We'll provide NumFunctions=1
      // and SPSA gradient inside Gradient().
      const auto& p = cfg_.optimizer.adam;

      LayoutSeparableSPSA f(&evaluator_, p.grad.evaluationStepSize);

      ens::Adam optimizer(p.stepSize, p.batchSize, p.beta1, p.beta2, p.eps,
                          p.maxIterations, p.tolerance, p.shuffle, p.resetPolicy, p.exactObjective);

      // Adam will call Evaluate(i, x) and Gradient(i, x, g) on f.
      optimizer.Optimize(f, x, cb);
      break;
    }

    case OptimizerId::GA:
    {
      RealCodedGA::Params gp;
      const auto& p = cfg_.optimizer.ga;

      gp.populationSize   = p.populationSize;
      gp.maxGenerations   = p.maxGenerations;
      gp.eliteFraction    = p.eliteFraction;
      gp.tournamentSize   = p.tournamentSize;
      gp.crossoverRate    = p.crossoverRate;
      gp.blendAlpha       = p.blendAlpha;
      gp.mutationRate     = p.mutationRate;
      gp.mutationSigma    = p.mutationSigma;
      gp.lowerBound       = p.lowerBound;
      gp.upperBound       = p.upperBound;
      gp.tolerance        = p.tolerance;
      gp.stallGenerations = p.stallGenerations;

      // derive bounds if omitted (same approach as PSO)
      const std::size_t dim = (std::size_t) x.n_rows;
      if (gp.lowerBound.size() != dim || gp.upperBound.size() != dim) {
        gp.lowerBound.assign(dim, 0.0);
        gp.upperBound.assign(dim, 0.0);
        const double W = cfg_.expected.canvas.W();
        const double H = cfg_.expected.canvas.H();
        for (std::size_t i = 0; i < dim; i += 2) {
          gp.lowerBound[i]   = 0.0;
          gp.upperBound[i]   = W;
          gp.lowerBound[i+1] = 0.0;
          gp.upperBound[i+1] = H;
        }
      }

      RealCodedGA ga(&evaluator_, &store_, &cb, gp,
                     cfg_.optimizer.common.stopping_criteria,
                     cfg_.optimizer.common.stopping_criteria_value);

      ga.Optimize(x);
      break;
    }

    default:
      throw std::runtime_error("Unsupported optimizer id.");
  }

  runtime_s_ = sw.Seconds();
  optimized_ = true;
}

4) JSON parsing: how to set OptimizerId FAST

Wherever you parse optimizer JSON (likely JsonIO::parse_config()):

Read common_pars into cfg.optimizer.common.

Find exactly one optimizer with "switch": true.

Set cfg.optimizer.id = ... enum.

Parse that optimizer’s parameters into the matching struct.

Important: do the string -> enum mapping once:

static OptimizerId ParseOptimizerId(const std::string& s) {
  if (s == "DE") return OptimizerId::DE;
  if (s == "SA") return OptimizerId::SA;
  if (s == "CNE") return OptimizerId::CNE;
  if (s == "PSO") return OptimizerId::PSO;
  if (s == "SPSA") return OptimizerId::SPSA;
  if (s == "ADAM") return OptimizerId::ADAM;
  if (s == "GA") return OptimizerId::GA;
  throw std::runtime_error("Unknown optimizer: " + s);
}


This keeps selection overhead effectively zero.

5) Notes you should not ignore
ADAM will be “ADAM over SPSA-gradient”

That’s intentional: your objective is piecewise / penalty-based / overlap-based, so a true analytic gradient is non-trivial and likely unstable. The SPSA-gradient inside Gradient() keeps per-step cost constant (2 objective calls) and works well in practice for these objectives.

History semantics

With the upgraded callback, for population optimizers you’ll store best-of-population per generation, which matches your GUI needs (slider over iterations).
