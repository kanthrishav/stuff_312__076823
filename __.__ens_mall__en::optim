void execute() {
  arma::arma_rng::set_seed(static_cast<arma::uword>(cfg_.optimizer.common.seed));

  LayoutObjective obj(&evaluator_);
  arma::mat x = evaluator_.initial_point();

  IterationCallback cb;
  cb.init(&evaluator_, &store_,
          cfg_.optimizer.common.stopping_criteria,
          cfg_.optimizer.common.stopping_criteria_value);

  Stopwatch sw;

  // Small helpers.
  auto clamp01_inplace = [](arma::mat& v, double lo, double hi) {
    // Works for column vector (2n x 1)
    for (arma::uword i = 0; i < v.n_elem; ++i) {
      if (v(i) < lo) v(i) = lo;
      else if (v(i) > hi) v(i) = hi;
    }
  };

  // --- ADAM wrapper: make your arbitrary objective look like a 1-function separable objective
  // with a fast SPSA-style gradient estimate (2 evals / gradient).
  struct AdamSeparableObjective {
    LayoutObjective* obj = nullptr;
    double perturb = 0.05;
    double noise = 0.0;
    double gamma = 0.101;
    std::uint64_t seed = 0;
    std::size_t k = 0;

    explicit AdamSeparableObjective(LayoutObjective* o) : obj(o) {}

    // 1 pseudo-function
    std::size_t NumFunctions() const { return 1; }

    // Some ensmallen APIs call Evaluate(x, start, batchSize)
    double Evaluate(const arma::mat& x, const std::size_t /*start*/, const std::size_t /*batchSize*/) {
      return obj->Evaluate(x);
    }
    // Some ensmallen APIs may call Evaluate(x)
    double Evaluate(const arma::mat& x) { return obj->Evaluate(x); }

    void Gradient(const arma::mat& x,
                  const std::size_t /*start*/,
                  arma::mat& g,
                  const std::size_t /*batchSize*/)
    {
      // SPSA-style gradient estimator: g ~= (f(x+cΔ)-f(x-cΔ)) / (2c) * Δ^{-1}
      // c_k = perturb / (k+1)^gamma
      const double ck = perturb / std::pow(double(k + 1), gamma);

      // Δ in {+1, -1}
      arma::mat delta(x.n_rows, x.n_cols);
      // deterministic-ish: rely on arma rng (seed already set)
      delta.randu();
      delta.transform([](double u) { return (u < 0.5) ? -1.0 : 1.0; });

      arma::mat xp = x + ck * delta;
      arma::mat xm = x - ck * delta;

      const double fp = obj->Evaluate(xp);
      const double fm = obj->Evaluate(xm);

      const double scale = (fp - fm) / (2.0 * ck);

      g.set_size(x.n_rows, x.n_cols);
      for (arma::uword i = 0; i < g.n_elem; ++i) {
        g(i) = scale / delta(i);
      }

      if (noise > 0.0) {
        arma::mat n(g.n_rows, g.n_cols);
        n.randn();
        g += noise * n;
      }

      ++k;
    }

    // Some variants call Gradient(x, g)
    void Gradient(const arma::mat& x, arma::mat& g) {
      Gradient(x, 0, g, 1);
    }
  };

  // --- GA (in-house, fast) ---
  auto run_ga = [&](const GAParams& p) {
    const arma::uword dim = x.n_elem;

    arma::mat pop(dim, p.populationSize);
    arma::rowvec fit(p.populationSize);

    // init around x with Gaussian noise
    arma::mat noise(dim, p.populationSize);
    noise.randn();
    pop.each_col() = x;
    pop += p.mutationSigma * noise;

    // bounds
    for (arma::uword j = 0; j < pop.n_cols; ++j) {
      arma::mat col = pop.col(j);
      clamp01_inplace(col, p.lowerBound, p.upperBound);
      pop.col(j) = col;
    }

    for (arma::uword j = 0; j < pop.n_cols; ++j) fit(j) = obj.Evaluate(pop.col(j));

    struct DummyOpt {} dummy;

    auto tournament_pick = [&](std::size_t K) -> arma::uword {
      arma::uword best = arma::uword(std::rand() % int(p.populationSize));
      double bestF = fit(best);
      for (std::size_t t = 1; t < K; ++t) {
        arma::uword idx = arma::uword(std::rand() % int(p.populationSize));
        if (fit(idx) < bestF) { best = idx; bestF = fit(idx); }
      }
      return best;
    };

    const std::size_t eliteN = std::max<std::size_t>(1, std::size_t(std::floor(p.elitePercent * double(p.populationSize))));

    for (std::size_t gen = 0; gen < p.maxGenerations; ++gen) {
      // sort indices by fitness (ascending)
      arma::uvec order = arma::sort_index(fit.t());

      // best-of-generation -> push to history via callback (consistent with other optimizers)
      arma::mat best = pop.col(order(0));
      const bool stop = cb.StepTaken(dummy, obj, best);
      x = best;
      if (stop) break;

      arma::mat next(dim, p.populationSize);

      // elites
      for (std::size_t e = 0; e < eliteN; ++e) {
        next.col(e) = pop.col(order(arma::uword(e)));
      }

      // offspring
      for (std::size_t j = eliteN; j < p.populationSize; ++j) {
        arma::uword a = tournament_pick(p.tournamentK);
        arma::uword b = tournament_pick(p.tournamentK);

        arma::mat child = pop.col(a);

        // blend crossover
        if (arma::randu() < p.crossoverRate) {
          const double alpha = arma::randu(); // [0,1]
          child = alpha * pop.col(a) + (1.0 - alpha) * pop.col(b);
        }

        // mutation
        if (arma::randu() < p.mutationProb) {
          arma::mat n(child.n_rows, child.n_cols);
          n.randn();
          child += p.mutationSigma * n;
        }

        clamp01_inplace(child, p.lowerBound, p.upperBound);
        next.col(j) = child;
      }

      pop = std::move(next);
      for (arma::uword j = 0; j < pop.n_cols; ++j) fit(j) = obj.Evaluate(pop.col(j));
    }
  };

  // -------------- FAST selection --------------
  switch (cfg_.optimizer.active) {
    case OptimizerKind::DE: {
      const auto& p = cfg_.optimizer.de;
      // DE(popSize, maxGenerations, crossoverRate, differentialWeight, tolerance) :contentReference[oaicite:9]{index=9}
      ens::DE opt(p.popsize, p.maxgen, p.crossover_rate, p.differential_weight, p.tolerance);
      opt.Optimize(obj, x, cb);
      break;
    }
    case OptimizerKind::SA: {
      const auto& p = cfg_.optimizer.sa;
      // SA uses ExponentialSchedule(lambda) by default :contentReference[oaicite:10]{index=10}
      ens::ExponentialSchedule sched(p.cooling_lambda);
      ens::SA<> opt(sched, p.maxIterations, p.initT, p.initMoves, p.moveCtrlSweep,
                   p.tolerance, p.maxToleranceSweep, p.maxMoveCoef, p.initMoveCoef, p.gain);
      opt.Optimize(obj, x, cb);
      break;
    }
    case OptimizerKind::CNE: {
      const auto& p = cfg_.optimizer.cne;
      // CNE(populationSize, maxGenerations, mutationProb, mutationSize, selectPercent, tolerance) :contentReference[oaicite:11]{index=11}
      ens::CNE opt(p.populationSize, p.maxGenerations, p.mutationProb, p.mutationSize, p.selectPercent, p.tolerance);
      opt.Optimize(obj, x, cb);
      break;
    }
    case OptimizerKind::PSO: {
      const auto& p = cfg_.optimizer.pso;
      // LBestPSO(..., lowerBound, upperBound, tolerance) :contentReference[oaicite:12]{index=12}
      ens::LBestPSO opt(p.numParticles, p.maxIterations,
                        p.inertiaWeight, p.cognitiveCoefficient, p.socialCoefficient,
                        p.maxVelocity, p.lowerBound, p.upperBound, p.tolerance);
      opt.Optimize(obj, x, cb);
      break;
    }
    case OptimizerKind::SPSA: {
      const auto& p = cfg_.optimizer.spsa;
      // SPSA(stepSize, batchSize, maxIterations, tolerance, alpha, gamma, perturb, noise) :contentReference[oaicite:13]{index=13}
      ens::SPSA opt(p.stepSize, p.batchSize, p.maxIterations, p.tolerance,
                    p.alpha, p.gamma, p.perturb, p.noise);
      opt.Optimize(obj, x, cb);
      break;
    }
    case OptimizerKind::ADAM: {
      const auto& p = cfg_.optimizer.adam;

      AdamSeparableObjective sobj(&obj);
      sobj.perturb = p.grad_perturb;
      sobj.noise = p.grad_noise;
      sobj.gamma = p.grad_gamma;
      sobj.seed = cfg_.optimizer.common.seed;

      // Adam(stepSize, batchSize, beta1, beta2, eps, maxIterations, tolerance, shuffle) :contentReference[oaicite:14]{index=14}
      ens::Adam opt(p.stepSize, p.batchSize, p.beta1, p.beta2, p.eps, p.maxIterations, p.tolerance, p.shuffle);
      opt.Optimize(sobj, x, cb);
      break;
    }
    case OptimizerKind::GA: {
      run_ga(cfg_.optimizer.ga);
      break;
    }
    default:
      throw std::runtime_error("Unsupported optimizer kind.");
  }

  runtime_s_ = sw.Seconds();
  optimized_ = true;
}

3) Notes that matter for speed + correctness

Selection overhead is negligible: config parsing sets OptimizerKind active once; runtime is a switch on a byte-sized enum.

Your existing early-stop mechanism still works: IterationCallback terminates only when stopping_criteria == "target_objective" and objective <= value.

Max-iter shouldn’t “random stop” anymore: most premature stops come from tolerance-like termination in optimizers. In the JSON above I defaulted tolerances to 0.0 to avoid convergence-based early termination when you want strict iteration caps.








