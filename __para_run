INSERT new sweep_all_combinations
std::shared_ptr<SweepResults> Runner::sweep_all_combinations(std::size_t max_workers,
                                                             std::uint64_t max_runs)
{
  ensure_inputs_loaded_();

  if (radices_.empty()) {
    throw std::runtime_error("sweep_all_combinations: no blocks in jBlock");
  }

  // Compute total combinations (uint64). Refuse overflow.
  std::uint64_t total = 1;
  for (std::size_t r : radices_) {
    std::uint64_t tmp = 0;
    if (mul_overflow_u64(total, static_cast<std::uint64_t>(r), tmp)) {
      throw std::runtime_error("Total combinations overflow uint64 (problem is too large). "
                               "Use max_runs to cap the sweep.");
    }
    total = tmp;
  }

  // Decide how many to run
  std::uint64_t runs = total;
  if (max_runs > 0) runs = std::min<std::uint64_t>(total, max_runs);

  // Refuse accidental impossible requests when max_runs==0 (exhaustive)
  // (adjust threshold if you want)
  constexpr std::uint64_t HARD_EXHAUSTIVE_CAP = 50'000'000ULL;
  if (max_runs == 0 && total > HARD_EXHAUSTIVE_CAP) {
    throw std::runtime_error("Exhaustive sweep requested but total combinations is too large (" +
                             std::to_string(total) +
                             "). Provide max_runs to cap the sweep.");
  }

  const std::size_t hw = std::max<std::size_t>(1, std::thread::hardware_concurrency());
  const std::size_t nthreads = std::max<std::size_t>(1, std::min(max_workers, hw));

  auto results = std::make_shared<SweepResults>(radices_, runs);

  std::atomic<std::uint64_t> next{0};

  // IMPORTANT PERFORMANCE NOTE:
  // This sweep is designed to store ONLY per-run BEST summary.
  // If your Placement always stores full history, that can dominate runtime/memory.
  // (See optional HistoryStore change below.)
  auto worker = [&]() {
    Placement local_place;              // thread-local, reused
    std::vector<int> varList;           // reused buffer
    for (;;) {
      const std::uint64_t run_i = next.fetch_add(1, std::memory_order_relaxed);
      if (run_i >= runs) break;

      const std::uint64_t combo_i = run_i;  // first runs combinations
      decode_mixed_radix(combo_i, radices_, varList);

      try {
        // load + run
        local_place.load(jPars_cache_, jBlock_cache_, varList);

        // OPTIONAL: make sweep faster by disabling full history storage
        // (requires the HistoryStore patch in section 3)
        // local_place.history_mutable().set_keep_history(false);

        local_place.execute();

        const auto& hs = local_place.history();
        results->set_ok(run_i, combo_i, local_place.runtime_seconds(), hs.best_metrics());
      }
      catch (const std::exception& e) {
        results->set_err(run_i, combo_i, e.what());
      }
      catch (...) {
        results->set_err(run_i, combo_i, "Unknown exception");
      }
    }
  };

  std::vector<std::thread> threads;
  threads.reserve(nthreads);
  for (std::size_t t = 0; t < nthreads; ++t) threads.emplace_back(worker);
  for (auto& th : threads) th.join();

  results->finalize_best();
  last_sweep_ = results;
  return results;
}

