#pragma once

#include <cstdint>
#include <cstddef>
#include <vector>
#include <string>
#include <array>
#include <limits>
#include <algorithm>

#include "data_classes.h"  // Metrics

class SweepResults {
public:
  SweepResults(std::vector<std::size_t> radices, std::uint64_t runs)
    : radices_(std::move(radices)),
      combo_index_(runs, 0),
      runtime_s_(runs, 0.0),
      best_obj_(runs, std::numeric_limits<double>::infinity()),
      status_(runs, 0),
      best_metrics_(runs),
      msg_(runs) {}

  std::size_t num_blocks() const noexcept { return radices_.size(); }
  std::uint64_t num_runs() const noexcept { return static_cast<std::uint64_t>(best_obj_.size()); }

  const std::vector<std::size_t>& radices() const noexcept { return radices_; }
  const std::vector<std::uint64_t>& combo_indices() const noexcept { return combo_index_; }
  const std::vector<double>& runtimes_s() const noexcept { return runtime_s_; }
  const std::vector<double>& best_objectives() const noexcept { return best_obj_; }
  const std::vector<std::uint32_t>& status_codes() const noexcept { return status_; }
  const std::vector<Metrics>& best_metrics_buffer() const noexcept { return best_metrics_; }

  // 0=OK, 1=ERR
  void set_ok(std::uint64_t run_i, std::uint64_t combo_i, double rt_s, const Metrics& bm) {
    combo_index_[run_i] = combo_i;
    runtime_s_[run_i]   = rt_s;
    best_obj_[run_i]    = bm.augmented_objective;
    status_[run_i]      = 0;
    best_metrics_[run_i]= bm;
    set_msg_(run_i, "");
  }

  void set_err(std::uint64_t run_i, std::uint64_t combo_i, const std::string& msg) {
    combo_index_[run_i] = combo_i;
    runtime_s_[run_i]   = 0.0;
    best_obj_[run_i]    = std::numeric_limits<double>::infinity();
    status_[run_i]      = 1;
    best_metrics_[run_i]= Metrics{};
    set_msg_(run_i, msg);
  }

  std::string message(std::size_t run_i) const {
    if (run_i >= msg_.size()) return "run_i out of range";
    const auto& a = msg_[run_i];
    return std::string(a.data());
  }

  // Decode mixed-radix combo_index -> varList (size = num_blocks)
  std::vector<int> decode_varlist(std::uint64_t combo) const {
    std::vector<int> v(radices_.size(), 0);
    for (std::size_t i = 0; i < radices_.size(); ++i) {
      const std::size_t base = radices_[i];
      if (base == 0) { v[i] = 0; continue; }
      v[i] = static_cast<int>(combo % static_cast<std::uint64_t>(base));
      combo /= static_cast<std::uint64_t>(base);
    }
    return v;
  }

  void finalize_best() {
    best_run_ = 0;
    best_obj_overall_ = std::numeric_limits<double>::infinity();
    for (std::size_t i = 0; i < best_obj_.size(); ++i) {
      if (status_[i] == 0 && best_obj_[i] < best_obj_overall_) {
        best_obj_overall_ = best_obj_[i];
        best_run_ = static_cast<std::uint64_t>(i);
      }
    }
  }

  std::uint64_t best_run_index() const noexcept { return best_run_; }
  std::uint64_t best_combo_index() const noexcept {
    if (best_run_ >= combo_index_.size()) return 0;
    return combo_index_[best_run_];
  }
  double best_objective() const noexcept { return best_obj_overall_; }
  Metrics best_overall_metrics() const noexcept {
    if (best_run_ >= best_metrics_.size()) return Metrics{};
    return best_metrics_[best_run_];
  }

private:
  void set_msg_(std::uint64_t run_i, const std::string& s) {
    auto& a = msg_[run_i];
    a.fill('\0');
    // truncate to fit
    const std::size_t n = std::min<std::size_t>(a.size() - 1, s.size());
    std::memcpy(a.data(), s.data(), n);
    a[n] = '\0';
  }

  std::vector<std::size_t> radices_;

  std::vector<std::uint64_t> combo_index_;
  std::vector<double> runtime_s_;
  std::vector<double> best_obj_;
  std::vector<std::uint32_t> status_;
  std::vector<Metrics> best_metrics_;
  std::vector<std::array<char, 192>> msg_;

  std::uint64_t best_run_{0};
  double best_obj_overall_{std::numeric_limits<double>::infinity()};
};


