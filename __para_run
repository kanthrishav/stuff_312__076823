  for (std::size_t i = 0; i < radices.size(); ++i) {
    const std::size_t base = radices[i];
    if (base == 0) { varList_out[i] = 0; continue; }
    varList_out[i] = static_cast<int>(combo % static_cast<std::uint64_t>(base));
    combo /= static_cast<std::uint64_t>(base);
  }
}

