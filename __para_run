MODIFY push(...) (do not append if keep_history_==false)
void push(const arma::mat& x, const Metrics& m){
  const double* p = x.memptr();
  const std::size_t this_iter = iter_count_;
  ++iter_count_;

  if (keep_history_) {
    iter_metrics_.push_back(m);
    coords_.insert(coords_.end(), p, p+(2*n_));
  }

  if(m.augmented_objective < best_obj_){
    best_obj_ = m.augmented_objective;
    best_metrics_ = m;
    best_index_ = keep_history_ ? (iter_metrics_.size() - 1) : this_iter;
    std::copy(p, p+(2*n_), best_coords_.begin());
  }
}

