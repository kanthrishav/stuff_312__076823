static bool mul_overflow_u64(std::uint64_t a, std::uint64_t b, std::uint64_t& out) {
  if (a == 0 || b == 0) { out = 0; return false; }
  if (a > (std::numeric_limits<std::uint64_t>::max() / b)) return true;
  out = a * b;
  return false;
}

static void decode_mixed_radix(std::uint64_t combo,
                              const std::vector<std::size_t>& radices,
                              std::vector<int>& varList_out)
