#pragma once
#include <nlohmann/json.hpp>
#include <algorithm>
#include <cmath>
#include <limits>
#include <stdexcept>

enum class variant_sort_criteria {
  area_asc,
  aspect_ratio_asc
};

// Returns a sortable key for a single variant (no allocations).
// Missing/invalid width/height -> +inf (pushed to the end).
static inline double variant_sort_key(const nlohmann::json& variant,
                                      variant_sort_criteria crit) noexcept {
  auto bad = []() noexcept {
    return std::numeric_limits<double>::infinity();
  };

  if (!variant.is_object()) return bad();
  if (!variant.contains("width") || !variant.contains("height")) return bad();
  if (!variant["width"].is_number() || !variant["height"].is_number()) return bad();

  const double w = variant["width"].get<double>();
  const double h = variant["height"].get<double>();
  if (!(w > 0.0) || !(h > 0.0)) return bad();

  if (crit == variant_sort_criteria::area_asc) {
    return w * h;
  }

  // aspect_ratio_asc: always >= 1.0
  const double r1 = w / h;
  const double r2 = h / w;
  return (r1 > r2) ? r1 : r2;
}

// In-place: modifies j_block by reordering variant arrays.
// No new JSON containers are created.
static inline void sort_variants_inplace(nlohmann::json& j_block,
                                         variant_sort_criteria crit) {
  if (!j_block.is_object()) {
    throw std::runtime_error("sort_variants_inplace: top-level JSON must be an object");
  }

  for (auto it = j_block.begin(); it != j_block.end(); ++it) {
    auto& variants = it.value();
    if (!variants.is_array() || variants.size() <= 1) continue;

    std::sort(variants.begin(), variants.end(),
      [&](const nlohmann::json& a, const nlohmann::json& b) noexcept {
        const double ka = variant_sort_key(a, crit);
        const double kb = variant_sort_key(b, crit);

        // Put "bad" (inf) at the end; otherwise ascending.
        if (ka == kb) return false;
        return ka < kb;
      }
    );
  }
}
